{
  "target": "MaximumLikelihood",
  "kind": "model_estimation",
  "source": "Exact oracle values: authored self-computed (M13), then verified value-for-value against the REAL RMC.BestFit MaximumLikelihood by tools/verify_oracles.py (M14 -- every literal reproduces bit-for-bit from the C# library, so these ARE C#-oracle values). Trend spec both ways: defaults-only Linear location trend, and explicit start_index + values (changes the deterministic NelderMead start; both cases pinned). Parameter layout: [trend intercept, trend slope, sigma]. NelderMead point values rel 1e-9 (T12 policy).",
  "datasets": {
    "trending_series": [
      980,
      1120,
      1230,
      1290,
      1410,
      1500,
      1580,
      1720,
      1840,
      1900,
      2050,
      2110,
      2230,
      2340,
      2410,
      2520,
      2660,
      2720,
      2850,
      2930
    ]
  },
  "cases": [
    {
      "name": "normal_linear_location_trend_defaults",
      "construct": {
        "model": {
          "type": "univariate_distribution",
          "family": "Normal",
          "dataset": "trending_series",
          "trends": [
            {
              "parameter": 0,
              "type": "Linear"
            }
          ]
        },
        "optimizer": "NelderMead"
      },
      "assertions": [
        {
          "method": "parameter",
          "args": [
            0
          ],
          "expected": 999.1501799477969,
          "mode": "rel",
          "tol": 1e-09
        },
        {
          "method": "parameter",
          "args": [
            1
          ],
          "expected": 102.1420915592524,
          "mode": "rel",
          "tol": 1e-09
        },
        {
          "method": "parameter",
          "args": [
            2
          ],
          "expected": 18.219683554436617,
          "mode": "rel",
          "tol": 1e-09
        },
        {
          "method": "max_log_likelihood",
          "args": [],
          "expected": -86.4322727673465,
          "mode": "rel",
          "tol": 1e-09
        }
      ]
    },
    {
      "name": "normal_linear_location_trend_explicit_start",
      "construct": {
        "model": {
          "type": "univariate_distribution",
          "family": "Normal",
          "dataset": "trending_series",
          "trends": [
            {
              "parameter": 0,
              "type": "Linear",
              "start_index": 0,
              "values": [
                1000.0,
                100.0
              ]
            }
          ]
        },
        "optimizer": "NelderMead"
      },
      "assertions": [
        {
          "method": "parameter",
          "args": [
            0
          ],
          "expected": 999.1401088498519,
          "mode": "rel",
          "tol": 1e-09
        },
        {
          "method": "parameter",
          "args": [
            1
          ],
          "expected": 102.14280177679139,
          "mode": "rel",
          "tol": 1e-09
        },
        {
          "method": "parameter",
          "args": [
            2
          ],
          "expected": 18.22410907077672,
          "mode": "rel",
          "tol": 1e-09
        },
        {
          "method": "max_log_likelihood",
          "args": [],
          "expected": -86.43227200968346,
          "mode": "rel",
          "tol": 1e-09
        }
      ]
    }
  ]
}
