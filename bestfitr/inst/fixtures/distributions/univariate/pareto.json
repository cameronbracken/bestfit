{
  "target": "Pareto",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_Pareto.cs",
  "reference": "Verified using Palisade @Risk and Accord.Net",
  "cases": [
    {
      "name": "pareto_0.42_3",
      "construct": { "params": [0.42, 3.0] },
      "assertions": [
        { "method": "pdf",      "args": [1.4],  "expected": 0.05785714285714286,  "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [1.4],  "expected": 0.973,                "mode": "abs", "tol": 1e-10 },
        { "method": "quantile", "args": [0.973],"expected": 1.4,                  "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.05], "expected": 0.4272428026402624,   "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.95], "expected": 1.1400553989698603,   "mode": "abs", "tol": 1e-4 },
        { "method": "mean",     "args": [], "expected": 0.63,                     "mode": "abs", "tol": 1e-10 },
        { "method": "median",   "args": [], "expected": 0.5291668409558468,       "mode": "abs", "tol": 1e-10 },
        { "method": "mode",     "args": [], "expected": 0.42,                     "mode": "abs", "tol": 1e-12 },
        { "method": "sd",       "args": [], "expected": 0.3637306695894642,       "mode": "abs", "tol": 1e-10 },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "pareto_1_10_moments",
      "construct": { "params": [1.0, 10.0] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 1.1111111111111112, "mode": "abs", "tol": 1e-10 },
        { "method": "median",   "args": [], "expected": 1.0717734625362931, "mode": "abs", "tol": 1e-10 },
        { "method": "mode",     "args": [], "expected": 1.0,                "mode": "abs", "tol": 1e-12 },
        { "method": "sd",       "args": [], "expected": 0.12422599874998831,"mode": "abs", "tol": 1e-10 },
        { "method": "skewness", "args": [], "expected": 2.8110568859997356, "mode": "abs", "tol": 1e-4 },
        { "method": "kurtosis", "args": [], "expected": 17.82857142857143,  "mode": "abs", "tol": 1e-4 },
        { "method": "minimum",  "args": [], "expected": 1.0,                "mode": "abs", "tol": 1e-12 },
        { "method": "maximum",  "args": [], "expected": "inf",              "mode": "equal" },
        { "method": "cdf",      "args": [0.0],  "expected": 0.0,            "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [2.0],  "expected": 0.9990234375,   "mode": "abs", "tol": 1e-10 },
        { "method": "quantile", "args": [0.0],  "expected": 1.0,            "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.3],  "expected": 1.0363112099103142, "mode": "abs", "tol": 1e-4 },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "pareto_1_1_pdf",
      "construct": { "params": [1.0, 1.0] },
      "assertions": [
        { "method": "pdf",    "args": [1.0],   "expected": 1.0,                "mode": "abs", "tol": 1e-12 },
        { "method": "pdf",    "args": [1.5],   "expected": 0.4444444444444444, "mode": "abs", "tol": 1e-12 },
        { "method": "median", "args": [],       "expected": 2.0,                "mode": "abs", "tol": 1e-12 },
        { "method": "mean",   "args": [],       "expected": "inf",              "mode": "equal" }
      ]
    },
    {
      "name": "pareto_3_2_pdf",
      "construct": { "params": [3.0, 2.0] },
      "assertions": [
        { "method": "pdf",    "args": [3.0],  "expected": 0.6666666666666666, "mode": "abs", "tol": 1e-12 },
        { "method": "pdf",    "args": [5.0],  "expected": 0.144,              "mode": "abs", "tol": 1e-12 },
        { "method": "sd",     "args": [],     "expected": "inf",               "mode": "equal" }
      ]
    },
    {
      "name": "pareto_1_3_skewness_nan",
      "construct": { "params": [1.0, 3.0] },
      "assertions": [
        { "method": "skewness", "args": [], "expected": "nan", "mode": "equal" }
      ]
    },
    {
      "name": "pareto_1_4_kurtosis_nan",
      "construct": { "params": [1.0, 4.0] },
      "assertions": [
        { "method": "kurtosis", "args": [], "expected": "nan", "mode": "equal" }
      ]
    },
    {
      "name": "invalid_nan_xm",
      "construct": { "params": ["nan", 1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "invalid_inf_xm",
      "construct": { "params": ["inf", 1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    }
  ]
}
