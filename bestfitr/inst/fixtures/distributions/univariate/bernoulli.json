{
  "target": "Bernoulli",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_Bernoulli.cs",
  "cases": [
    {
      "name": "p0.7_atRisk",
      "construct": { "params": [0.7] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 0.7,    "mode": "abs", "tol": 1e-4 },
        { "method": "median",   "args": [], "expected": 1.0,    "mode": "abs", "tol": 1e-4 },
        { "method": "mode",     "args": [], "expected": 1.0,    "mode": "abs", "tol": 1e-4 },
        { "method": "sd",       "args": [], "expected": 0.4583, "mode": "abs", "tol": 1e-4 },
        { "method": "skewness", "args": [], "expected": -0.8729, "mode": "abs", "tol": 1e-4 },
        { "method": "kurtosis", "args": [], "expected": 1.7619, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf",      "args": [0.0], "expected": 0.3, "mode": "abs", "tol": 1e-4 },
        { "method": "cdf",      "args": [0.5], "expected": 0.3, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.05], "expected": 0.0, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.95], "expected": 1.0, "mode": "abs", "tol": 1e-4 },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "p0.3",
      "construct": { "params": [0.3] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 0.3,       "mode": "abs", "tol": 1e-4 },
        { "method": "median",   "args": [], "expected": 0.0,       "mode": "abs", "tol": 1e-4 },
        { "method": "mode",     "args": [], "expected": 0.0,       "mode": "abs", "tol": 1e-4 },
        { "method": "sd",       "args": [], "expected": 0.458257,  "mode": "abs", "tol": 1e-4 },
        { "method": "skewness", "args": [], "expected": 0.8728715, "mode": "abs", "tol": 1e-4 },
        { "method": "kurtosis", "args": [], "expected": 1.761904762, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf",      "args": [-1.0], "expected": 0.0,  "mode": "abs", "tol": 1e-12 },
        { "method": "pdf",      "args": [0.0],  "expected": 0.7,  "mode": "abs", "tol": 1e-4 },
        { "method": "pdf",      "args": [1.0],  "expected": 0.3,  "mode": "abs", "tol": 1e-4 },
        { "method": "pdf",      "args": [2.0],  "expected": 0.0,  "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [-1.0], "expected": 0.0,  "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [0.0],  "expected": 0.7,  "mode": "abs", "tol": 1e-4 },
        { "method": "cdf",      "args": [0.5],  "expected": 0.7,  "mode": "abs", "tol": 1e-4 },
        { "method": "cdf",      "args": [1.0],  "expected": 1.0,  "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.3],  "expected": 0.0,  "mode": "abs", "tol": 1e-4 },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "p0.5_boundary",
      "construct": { "params": [0.5] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 0.5, "mode": "abs", "tol": 1e-4 },
        { "method": "median",   "args": [], "expected": 0.5, "mode": "abs", "tol": 1e-4 },
        { "method": "mode",     "args": [], "expected": 0.0, "mode": "abs", "tol": 1e-4 },
        { "method": "skewness", "args": [], "expected": 0.0, "mode": "abs", "tol": 1e-10 },
        { "method": "kurtosis", "args": [], "expected": 1.0, "mode": "abs", "tol": 1e-10 },
        { "method": "quantile", "args": [0.7], "expected": 1.0, "mode": "abs", "tol": 1e-4 },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    }
  ]
}
