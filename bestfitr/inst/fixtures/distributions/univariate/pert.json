{
  "target": "Pert",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_Pert.cs",
  "datasets": {
    "mom_exact": [0.0, 2.0, 4.0, 6.0, 10.0]
  },
  "cases": [
    {
      "name": "default_0_0p5_1",
      "construct": { "params": [0.0, 0.5, 1.0] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 0.5,     "mode": "abs", "tol": 1e-10 },
        { "method": "median",   "args": [], "expected": 0.5,     "mode": "abs", "tol": 1e-10 },
        { "method": "mode",     "args": [], "expected": 0.5,     "mode": "abs", "tol": 1e-10 },
        { "method": "sd",       "args": [], "expected": 0.1889,  "mode": "abs", "tol": 1e-4 },
        { "method": "skewness", "args": [], "expected": 0.0,     "mode": "abs", "tol": 1e-10 },
        { "method": "kurtosis", "args": [], "expected": 2.3333,  "mode": "abs", "tol": 1e-4 },
        { "method": "minimum",  "args": [], "expected": 0.0,     "mode": "equal" },
        { "method": "maximum",  "args": [], "expected": 1.0,     "mode": "equal" },
        { "method": "param",    "args": [0], "expected": 0.0,    "mode": "abs", "tol": 1e-12 },
        { "method": "param",    "args": [1], "expected": 0.5,    "mode": "abs", "tol": 1e-12 },
        { "method": "param",    "args": [2], "expected": 1.0,    "mode": "abs", "tol": 1e-12 },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "pert_1_2_3",
      "construct": { "params": [1.0, 2.0, 3.0] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 2.0, "mode": "abs", "tol": 1e-4 },
        { "method": "median",   "args": [], "expected": 2.0, "mode": "abs", "tol": 1e-4 },
        { "method": "mode",     "args": [], "expected": 2.0, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf",      "args": [1.27], "expected": 0.20454600937499817, "mode": "abs", "tol": 1e-4 },
        { "method": "cdf",      "args": [1.27], "expected": 0.019890532631249999, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.019890532631249999], "expected": 1.27, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "pert_neg1_0_1_R",
      "construct": { "params": [-1.0, 0.0, 1.0] },
      "assertions": [
        { "method": "pdf",      "args": [-0.5], "expected": 0.5273438, "mode": "abs", "tol": 1e-5 },
        { "method": "cdf",      "args": [-0.5], "expected": 0.1035156, "mode": "abs", "tol": 1e-5 },
        { "method": "quantile", "args": [0.1035156], "expected": -0.5, "mode": "abs", "tol": 1e-5 }
      ]
    },
    {
      "name": "pert_0_0p25_1_R",
      "construct": { "params": [0.0, 0.25, 1.0] },
      "assertions": [
        { "method": "cdf",      "args": [0.1],  "expected": 0.0814600, "mode": "abs", "tol": 1e-7 },
        { "method": "cdf",      "args": [0.25], "expected": 0.3671875, "mode": "abs", "tol": 1e-7 },
        { "method": "cdf",      "args": [0.5],  "expected": 0.8125000, "mode": "abs", "tol": 1e-7 },
        { "method": "cdf",      "args": [0.75], "expected": 0.9843750, "mode": "abs", "tol": 1e-7 },
        { "method": "cdf",      "args": [0.9],  "expected": 0.9995400, "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0.0814600], "expected": 0.1,  "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0.3671875], "expected": 0.25, "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0.8125000], "expected": 0.5,  "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0.9843750], "expected": 0.75, "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0.9995400], "expected": 0.9,  "mode": "abs", "tol": 1e-7 }
      ]
    },
    {
      "name": "min_max_1_1p5_2",
      "construct": { "params": [1.0, 1.5, 2.0] },
      "assertions": [
        { "method": "minimum", "args": [], "expected": 1.0, "mode": "equal" },
        { "method": "maximum", "args": [], "expected": 2.0, "mode": "equal" }
      ]
    },
    {
      "name": "invalid_min_gt_max",
      "construct": { "params": [3.0, 2.0, 1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "invalid_mode_gt_max",
      "construct": { "params": [1.0, 2.0, 0.5] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "mom_fit_exact",
      "construct": { "fit": { "method": "mom", "dataset": "mom_exact" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 0.0,  "mode": "abs", "tol": 1e-9 },
        { "method": "param", "args": [1], "expected": 4.1,  "mode": "abs", "tol": 1e-9 },
        { "method": "param", "args": [2], "expected": 10.0, "mode": "abs", "tol": 1e-9 }
      ]
    }
  ]
}
