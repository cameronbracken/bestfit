{
  "target": "StudentT",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_StudentT.cs",
  "cases": [
    {
      "name": "student_t_default_mu0_sigma1_nu10_moments",
      "note": "Default constructor: mu=0, sigma=1, nu=10; Test_Construction, Test_Mean, Test_Median, Test_Mode, Test_StandardDeviation, Test_Skewness, Test_Kurtosis",
      "construct": { "params": [0.0, 1.0, 10.0] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 0.0,               "mode": "abs", "tol": 1e-12 },
        { "method": "median",   "args": [], "expected": 0.0,               "mode": "abs", "tol": 1e-12 },
        { "method": "mode",     "args": [], "expected": 0.0,               "mode": "abs", "tol": 1e-12 },
        { "method": "sd",       "args": [], "expected": 1.118033988749895, "mode": "abs", "tol": 1e-8 },
        { "method": "skewness", "args": [], "expected": 0.0,               "mode": "abs", "tol": 1e-12 },
        { "method": "kurtosis", "args": [], "expected": 4.0,               "mode": "abs", "tol": 1e-12 },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "student_t_standard_nu4_pdf_cdf",
      "note": "Test_StudentT_PDF, Test_StudentT_CDF: StudentT(nu=4) at x=1.4; C# uses mu=0,sigma=1,nu=4",
      "construct": { "params": [0.0, 1.0, 4.0] },
      "assertions": [
        { "method": "pdf",      "args": [1.4], "expected": 0.138377537135553,  "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [1.4], "expected": 0.882949686336585,  "mode": "abs", "tol": 1e-10 },
        { "method": "quantile", "args": [0.882949686336585], "expected": 1.4,  "mode": "abs", "tol": 1e-2 },
        { "method": "median",   "args": [], "expected": 0.0,  "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.5], "expected": 0.0, "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "student_t_shifted_mu2p5_sigma0p5_nu4",
      "note": "Test_StudentT_PDF, Test_StudentT_CDF: StudentT(2.5, 0.5, 4) at x=1.4",
      "construct": { "params": [2.5, 0.5, 4.0] },
      "assertions": [
        { "method": "pdf",      "args": [1.4], "expected": 0.0516476521260042,  "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [1.4], "expected": 0.0463263350898173,  "mode": "abs", "tol": 1e-10 },
        { "method": "quantile", "args": [0.0463263350898173], "expected": 1.4,  "mode": "abs", "tol": 1e-2 },
        { "method": "median",   "args": [], "expected": 2.5, "mode": "abs", "tol": 1e-12 },
        { "method": "mode",     "args": [], "expected": 2.5, "mode": "abs", "tol": 1e-12 },
        { "method": "mean",     "args": [], "expected": 2.5, "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "student_t_nu1_undefined_moments",
      "note": "Test_Mean, Test_Median, Test_Mode, Test_StandardDeviation, Test_Skewness: nu=1 edge cases",
      "construct": { "params": [1.0, 1.0, 1.0] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": "nan", "mode": "equal" },
        { "method": "sd",       "args": [], "expected": "nan", "mode": "equal" },
        { "method": "skewness", "args": [], "expected": "nan", "mode": "equal" },
        { "method": "median",   "args": [], "expected": 1.0,   "mode": "abs", "tol": 1e-12 },
        { "method": "mode",     "args": [], "expected": 1.0,   "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "student_t_nu2_infinite_sd",
      "note": "Test_StandardDeviation: nu=2 -> sd=+Inf; Test_Kurtosis: nu<=2 -> kurtosis=NaN",
      "construct": { "params": [1.0, 1.0, 2.0] },
      "assertions": [
        { "method": "sd",       "args": [], "expected": "inf", "mode": "equal" },
        { "method": "kurtosis", "args": [], "expected": "nan", "mode": "equal" }
      ]
    },
    {
      "name": "student_t_nu4_infinite_kurtosis",
      "note": "Test_Kurtosis: nu=4 -> kurtosis=+Inf",
      "construct": { "params": [1.0, 1.0, 4.0] },
      "assertions": [
        { "method": "kurtosis", "args": [], "expected": "inf", "mode": "equal" }
      ]
    },
    {
      "name": "student_t_symmetry_tail_quantiles",
      "note": "Symmetry: InverseCDF(1-p) = -InverseCDF(p) + 2*mu; tail quantiles exercise incomplete_inverse",
      "construct": { "params": [0.0, 1.0, 10.0] },
      "assertions": [
        { "method": "quantile", "args": [0.5],   "expected": 0.0,   "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.025],  "expected": -2.228138852121985, "mode": "abs", "tol": 1e-2 },
        { "method": "quantile", "args": [0.975],  "expected":  2.228138852121985, "mode": "abs", "tol": 1e-2 },
        { "method": "quantile", "args": [0.01],   "expected": -2.763769457931383, "mode": "abs", "tol": 1e-2 },
        { "method": "quantile", "args": [0.99],   "expected":  2.763769457931383, "mode": "abs", "tol": 1e-2 }
      ]
    },
    {
      "name": "student_t_large_df_normal_approx",
      "note": "nu=1e8 >= 1e8 threshold: PDF/CDF degrade to standard normal approximation",
      "construct": { "params": [0.0, 1.0, 100000000.0] },
      "assertions": [
        { "method": "pdf", "args": [0.0], "expected": 0.3989422804014327, "mode": "abs", "tol": 1e-10 },
        { "method": "cdf", "args": [0.0], "expected": 0.5, "mode": "abs", "tol": 1e-12 },
        { "method": "cdf", "args": [1.96], "expected": 0.9750021048517796, "mode": "abs", "tol": 1e-5 }
      ]
    },
    {
      "name": "student_t_invalid_params",
      "note": "sigma<=0 or nu<1 -> parameters_valid = false; Test_InvalidParameters",
      "construct": { "params": [0.0, -1.0, 1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "student_t_invalid_nu_zero",
      "note": "nu=0 < 1 -> parameters_valid = false",
      "construct": { "params": [1.0, 1.0, 0.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    }
  ]
}
