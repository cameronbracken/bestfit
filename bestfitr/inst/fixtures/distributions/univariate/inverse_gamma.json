{
  "target": "InverseGamma",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_InverseGamma.cs",
  "cases": [
    {
      "name": "default_moments_pdf_cdf_quantile",
      "construct": { "params": [0.5, 2.0] },
      "assertions": [
        { "method": "mean",             "args": [],     "expected": 0.5,             "mode": "abs", "tol": 1e-12 },
        { "method": "median",           "args": [],     "expected": 0.2979,          "mode": "abs", "tol": 1e-4  },
        { "method": "mode",             "args": [],     "expected": 0.1666,          "mode": "abs", "tol": 1e-4  },
        { "method": "sd",               "args": [],     "expected": "nan",           "mode": "equal"            },
        { "method": "skewness",         "args": [],     "expected": "nan",           "mode": "equal"            },
        { "method": "kurtosis",         "args": [],     "expected": "nan",           "mode": "equal"            },
        { "method": "parameters_valid", "args": [],     "expected": true,            "mode": "bool"             }
      ]
    },
    {
      "name": "alpha_le1_mean_nan",
      "construct": { "params": [1.0, 1.0] },
      "assertions": [
        { "method": "mean",   "args": [], "expected": "nan", "mode": "equal" },
        { "method": "mode",   "args": [], "expected": 0.5, "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "sd_finite_alpha3",
      "construct": { "params": [0.5, 3.0] },
      "assertions": [
        { "method": "sd", "args": [], "expected": 0.25, "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "skewness_finite_alpha4",
      "construct": { "params": [0.5, 4.0] },
      "assertions": [
        { "method": "skewness", "args": [], "expected": 5.65685, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "kurtosis_finite_alpha5",
      "construct": { "params": [0.5, 5.0] },
      "assertions": [
        { "method": "kurtosis", "args": [], "expected": 45.0, "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "pdf_beta2_alpha4",
      "construct": { "params": [2.0, 4.0] },
      "assertions": [
        { "method": "pdf",      "args": [5.0],  "expected": 0.00057200,  "mode": "abs", "tol": 1e-7  },
        { "method": "pdf",      "args": [0.42], "expected": 1.74443,     "mode": "abs", "tol": 1e-4  },
        { "method": "pdf",      "args": [-2.0], "expected": 0.0,         "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "cdf_quantile_beta2_alpha2",
      "construct": { "params": [2.0, 2.0] },
      "assertions": [
        { "method": "cdf",      "args": [2.0],  "expected": 0.73575,     "mode": "abs", "tol": 1e-4  },
        { "method": "cdf",      "args": [-1.0], "expected": 0.0,         "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.0],  "expected": 0.0,         "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.3],  "expected": 0.81993,     "mode": "abs", "tol": 1e-4  }
      ]
    },
    {
      "name": "pdf_beta042_alpha24",
      "construct": { "params": [0.42, 2.4] },
      "assertions": [
        { "method": "pdf", "args": [0.3], "expected": 1.48386, "mode": "abs", "tol": 1e-5 }
      ]
    },
    {
      "name": "cdf_quantile_roundtrip_beta05_alpha042",
      "construct": { "params": [0.5, 0.42] },
      "assertions": [
        { "method": "median",   "args": [],     "expected": 3.1072323347401709, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf",      "args": [0.27], "expected": 0.35679850067181362, "mode": "abs", "tol": 1e-4 },
        { "method": "cdf",      "args": [0.27], "expected": 0.042243552114989695, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.042243552114989695], "expected": 0.26999994629410995, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "invalid_params_zero",
      "construct": { "params": [0.0, 0.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "minimum_maximum",
      "construct": { "params": [0.5, 2.0] },
      "assertions": [
        { "method": "minimum", "args": [], "expected": 0.0, "mode": "abs", "tol": 1e-12 }
      ]
    }
  ]
}
