{
  "target": "Uniform",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_Uniform.cs",
  "reference": "Accord.NET; R 'stats'; math.net DistributionTests",
  "datasets": {},
  "cases": [
    {
      "name": "accord_0p42_1p1",
      "construct": { "params": [0.42, 1.1] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 0.76, "mode": "abs", "tol": 1e-4 },
        { "method": "median",   "args": [], "expected": 0.76, "mode": "abs", "tol": 1e-4 },
        { "method": "sd",       "args": [], "expected": 0.19629907, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf",      "args": [0.9], "expected": 1.4705882352941173, "mode": "abs", "tol": 1e-4 },
        { "method": "cdf",      "args": [0.9], "expected": 0.70588235294117641, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.70588235294117641], "expected": 0.9, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "standard_unit",
      "construct": { "params": [0, 1] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 0.5, "mode": "equal" },
        { "method": "median",   "args": [], "expected": 0.5, "mode": "equal" },
        { "method": "mode",     "args": [], "expected": "nan", "mode": "equal" },
        { "method": "sd",       "args": [], "expected": 0.288675, "mode": "abs", "tol": 1e-5 },
        { "method": "skewness", "args": [], "expected": 0, "mode": "equal" },
        { "method": "kurtosis", "args": [], "expected": 1.8, "mode": "abs", "tol": 1e-12 },
        { "method": "minimum",  "args": [], "expected": 0, "mode": "equal" },
        { "method": "maximum",  "args": [], "expected": 1, "mode": "equal" },
        { "method": "pdf", "args": [-1], "expected": 0, "mode": "equal" },
        { "method": "pdf", "args": [2],  "expected": 0, "mode": "equal" },
        { "method": "pdf", "args": [1],  "expected": 1, "mode": "equal" },
        { "method": "cdf", "args": [0],   "expected": 0,   "mode": "equal" },
        { "method": "cdf", "args": [1],   "expected": 1,   "mode": "equal" },
        { "method": "cdf", "args": [0.5], "expected": 0.5, "mode": "equal" },
        { "method": "cdf", "args": [0.25], "expected": 0.25, "mode": "abs", "tol": 1e-7 },
        { "method": "cdf", "args": [0.9],  "expected": 0.9,  "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0],   "expected": 0,   "mode": "equal" },
        { "method": "quantile", "args": [1],   "expected": 1,   "mode": "equal" },
        { "method": "quantile", "args": [0.3], "expected": 0.3, "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0.75], "expected": 0.75, "mode": "abs", "tol": 1e-7 },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "u_2_10",
      "construct": { "params": [2, 10] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 6, "mode": "equal" },
        { "method": "median",   "args": [], "expected": 6, "mode": "equal" },
        { "method": "mode",     "args": [], "expected": "nan", "mode": "equal" },
        { "method": "sd",       "args": [], "expected": 2.3094, "mode": "abs", "tol": 1e-4 },
        { "method": "skewness", "args": [], "expected": 0, "mode": "equal" },
        { "method": "kurtosis", "args": [], "expected": 1.8, "mode": "abs", "tol": 1e-12 },
        { "method": "minimum",  "args": [], "expected": 2,  "mode": "equal" },
        { "method": "maximum",  "args": [], "expected": 10, "mode": "equal" }
      ]
    },
    {
      "name": "invalid_min_gt_max",
      "construct": { "params": [1, 0] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "invalid_nan_min",
      "construct": { "params": ["nan", 0] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "invalid_nan_max",
      "construct": { "params": [0, "nan"] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "invalid_inf_max",
      "construct": { "params": [0, "inf"] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "invalid_inf_min",
      "construct": { "params": ["inf", 0] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    }
  ]
}
