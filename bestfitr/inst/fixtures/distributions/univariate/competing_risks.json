{
  "target": "CompetingRisks",
  "kind":   "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_CompetingRisks.cs",
  "reference": "Python 'reliability' package; analytical solutions verified against C# Numerics",
  "cases": [
    {
      "name": "two_normal_min_rule",
      "construct": {
        "components": [
          {"target": "Normal", "params": [100.0, 10.0]},
          {"target": "Normal", "params": [110.0, 15.0]}
        ],
        "minimum_of_random_variables": true
      },
      "assertions": [
        { "method": "cdf",      "args": [90.0],  "expected": 0.23539533443031946, "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [105.0], "expected": 0.80544898307732449, "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [130.0], "expected": 0.99987687415402948, "mode": "abs", "tol": 1e-10 },
        { "method": "pdf",      "args": [90.0],  "expected": 0.031189295601843799,"mode": "abs", "tol": 1e-8  },
        { "method": "pdf",      "args": [100.0], "expected": 0.040469500019556959,"mode": "abs", "tol": 1e-8  },
        { "method": "pdf",      "args": [110.0], "expected": 0.016318155479362752,"mode": "abs", "tol": 1e-8  },
        { "method": "quantile", "args": [0.05],  "expected": 80.54490302866887,   "mode": "abs", "tol": 1e-4  },
        { "method": "quantile", "args": [0.50],  "expected": 96.96709555244928,   "mode": "abs", "tol": 1e-4  },
        { "method": "quantile", "args": [0.95],  "expected": 112.12362757263723,  "mode": "abs", "tol": 1e-4  },
        { "method": "mean",     "args": [],       "expected": 96.729020376712626,  "mode": "abs", "tol": 1e-2  },
        { "method": "median",   "args": [],       "expected": 96.96709555244928,   "mode": "abs", "tol": 1e-4  },
        { "method": "sd",       "args": [],       "expected": 9.6325409108296114,  "mode": "abs", "tol": 1e-2  },
        { "method": "skewness", "args": [],       "expected": -0.1730096720442989, "mode": "abs", "tol": 1e-2  },
        { "method": "kurtosis", "args": [],       "expected": 3.1910124193664839,  "mode": "abs", "tol": 1e-2  },
        { "method": "minimum",  "args": [],       "expected": "-inf",              "mode": "equal"             },
        { "method": "maximum",  "args": [],       "expected": "inf",               "mode": "equal"             },
        { "method": "parameters_valid", "args": [], "expected": true,             "mode": "bool"              }
      ]
    },
    {
