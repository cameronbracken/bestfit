{
  "target": "TruncatedNormal",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_TruncatedNormal.cs",
  "reference": "Sugiura & Gomi, Pearson diagrams for truncated normal and truncated Weibull distributions, 1985",
  "cases": [
    {
      "name": "default_moments",
      "construct": { "params": [0.5, 0.2, 0.0, 1.0] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 0.5, "mode": "abs", "tol": 1e-12 },
        { "method": "median",   "args": [], "expected": 0.5, "mode": "abs", "tol": 1e-12 },
        { "method": "mode",     "args": [], "expected": 0.5, "mode": "abs", "tol": 1e-12 },
        { "method": "sd",       "args": [], "expected": 0.19091949726891616, "mode": "abs", "tol": 1e-8 },
        { "method": "skewness", "args": [], "expected": 0.0, "mode": "abs", "tol": 1e-10 },
        { "method": "kurtosis", "args": [], "expected": 2.624220160927584, "mode": "abs", "tol": 1e-6 },
        { "method": "minimum",  "args": [], "expected": 0.0, "mode": "equal" },
        { "method": "maximum",  "args": [], "expected": 1.0, "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "pdf_cdf_icdf_case1",
      "construct": { "params": [2.0, 1.0, 1.10, 2.11] },
      "assertions": [
        { "method": "pdf",      "args": [1.5], "expected": 0.9786791487064394, "mode": "abs", "tol": 1e-6 },
        { "method": "cdf",      "args": [1.5], "expected": 0.34602512573105537, "mode": "abs", "tol": 1e-6 },
        { "method": "quantile", "args": [0.34602512573105537], "expected": 1.5, "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "pdf_cdf_icdf_case2",
      "construct": { "params": [10.0, 3.0, 8.0, 25.0] },
      "assertions": [
        { "method": "pdf",      "args": [12.75], "expected": 0.11687172224457536, "mode": "abs", "tol": 1e-6 },
        { "method": "cdf",      "args": [12.75], "expected": 0.7596566450073511,  "mode": "abs", "tol": 1e-6 },
        { "method": "quantile", "args": [0.7596566450073511], "expected": 12.75, "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "pdf_cdf_icdf_case3",
      "construct": { "params": [0.0, 3.0, 0.0, 9.0] },
      "assertions": [
        { "method": "pdf",      "args": [4.5], "expected": 0.08657880890470383, "mode": "abs", "tol": 1e-6 },
        { "method": "cdf",      "args": [4.5], "expected": 0.8687309939798628,  "mode": "abs", "tol": 1e-6 },
        { "method": "quantile", "args": [0.8687309939798628], "expected": 4.5, "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "boundary_cdf",
      "construct": { "params": [0.5, 0.2, 0.0, 1.0] },
      "assertions": [
        { "method": "cdf", "args": [0.0],  "expected": 0.0, "mode": "equal" },
        { "method": "cdf", "args": [1.0],  "expected": 1.0, "mode": "equal" },
        { "method": "quantile", "args": [0.0], "expected": 0.0, "mode": "equal" },
        { "method": "quantile", "args": [1.0], "expected": 1.0, "mode": "equal" }
      ]
    },
    {
      "name": "invalid_bad_sigma",
      "construct": { "params": [0.0, -1.0, -1.0, 0.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "invalid_min_gt_max",
      "construct": { "params": [1.0, 1.0, 1.0, 0.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    }
  ]
}
