{
  "target": "Dirichlet",
  "kind": "multivariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Multivariate/Test_Dirichlet.cs",
  "reference": "Reference values verified analytically and against R package MCMCpack::ddirichlet.",
  "note": "Sampling (Test_Sampling), Clone, and CDF_Throws are not covered here -- sampling gets seeded first-N oracles in a later task; Clone/CDF-throws are not fixture-observable behavior.",
  "cases": [
    {
      "name": "symmetric_construction",
      "construct": { "alpha": [2.0, 2.0, 2.0] },
      "assertions": [
        { "method": "dimension", "args": [], "expected": 3, "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" },
        { "method": "alpha", "args": [0], "expected": 2.0, "mode": "equal" },
        { "method": "alpha_sum", "args": [], "expected": 6.0, "mode": "equal" }
      ]
    },
    {
      "name": "asymmetric_construction",
      "construct": { "alpha": [1.0, 2.0, 3.0] },
      "assertions": [
        { "method": "dimension", "args": [], "expected": 3, "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" },
        { "method": "alpha_sum", "args": [], "expected": 6.0, "mode": "equal" }
      ]
    },
    {
      "name": "mean_symmetric",
      "construct": { "alpha": [2.0, 2.0, 2.0] },
      "assertions": [
        { "method": "mean", "args": [0], "expected": 0.3333333333333333, "mode": "abs", "tol": 1e-10 },
        { "method": "mean", "args": [1], "expected": 0.3333333333333333, "mode": "abs", "tol": 1e-10 },
        { "method": "mean", "args": [2], "expected": 0.3333333333333333, "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "mean_asymmetric",
      "construct": { "alpha": [1.0, 2.0, 3.0] },
      "assertions": [
        { "method": "mean", "args": [0], "expected": 0.16666666666666666, "mode": "abs", "tol": 1e-10 },
        { "method": "mean", "args": [1], "expected": 0.3333333333333333, "mode": "abs", "tol": 1e-10 },
        { "method": "mean", "args": [2], "expected": 0.5, "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "variance",
      "construct": { "alpha": [1.0, 2.0, 3.0] },
      "assertions": [
        { "method": "variance", "args": [0], "expected": 0.01984126984126984, "mode": "abs", "tol": 1e-10 },
        { "method": "variance", "args": [1], "expected": 0.031746031746031744, "mode": "abs", "tol": 1e-10 },
        { "method": "variance", "args": [2], "expected": 0.03571428571428571, "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "mode",
      "construct": { "alpha": [2.0, 3.0, 5.0] },
      "assertions": [
        { "method": "mode", "args": [0], "expected": 0.14285714285714285, "mode": "abs", "tol": 1e-10 },
        { "method": "mode", "args": [1], "expected": 0.2857142857142857, "mode": "abs", "tol": 1e-10 },
        { "method": "mode", "args": [2], "expected": 0.5714285714285714, "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "covariance",
      "construct": { "alpha": [1.0, 2.0, 3.0] },
      "assertions": [
        { "method": "covariance", "args": [0, 1], "expected": -0.007936507936507936, "mode": "abs", "tol": 1e-10 },
        { "method": "covariance", "args": [0, 0], "expected": 0.01984126984126984, "mode": "abs", "tol": 1e-10 },
        { "method": "covariance", "args": [1, 0], "expected": -0.007936507936507936, "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "pdf_uniform",
      "construct": { "alpha": [1.0, 1.0, 1.0] },
      "assertions": [
        { "method": "pdf", "args": [[0.3333333333333333, 0.3333333333333333, 0.3333333333333333]], "expected": 2.0, "mode": "abs", "tol": 1e-6 },
        { "method": "pdf", "args": [[0.1, 0.2, 0.7]], "expected": 2.0, "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "pdf_asymmetric",
      "construct": { "alpha": [2.0, 3.0, 5.0] },
      "assertions": [
        { "method": "pdf", "args": [[0.1, 0.3, 0.6]], "expected": 8.817984, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "pdf_outside_simplex",
      "construct": { "alpha": [2.0, 2.0, 2.0] },
      "assertions": [
        { "method": "pdf", "args": [[0.5, 0.5, 0.5]], "expected": 0.0, "mode": "abs", "tol": 1e-10 },
        { "method": "pdf", "args": [[-0.1, 0.6, 0.5]], "expected": 0.0, "mode": "abs", "tol": 1e-10 },
        { "method": "pdf", "args": [[0.5, 0.5]], "expected": 0.0, "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "log_pdf",
      "construct": { "alpha": [1.0, 1.0, 1.0] },
      "assertions": [
        { "method": "log_pdf", "args": [[0.3333333333333333, 0.3333333333333333, 0.3333333333333333]], "expected": 0.6931471805599453, "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "log_pdf_invalid",
      "construct": { "alpha": [1.0, 2.0, 3.0] },
      "assertions": [
        { "method": "log_pdf", "args": [[0.5, 0.5]], "expected": "-inf", "mode": "equal" },
        { "method": "log_pdf", "args": [[-0.1, 0.6, 0.5]], "expected": "-inf", "mode": "equal" },
        { "method": "log_pdf", "args": [[0.3, 0.3, 0.3]], "expected": "-inf", "mode": "equal" }
      ]
    },
    {
      "name": "log_multivariate_beta_2",
      "construct": { "alpha": [1.0, 1.0] },
      "assertions": [
        { "method": "log_multivariate_beta", "args": [1.0, 1.0], "expected": 0.0, "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "log_multivariate_beta_3",
      "construct": { "alpha": [1.0, 1.0, 1.0] },
      "assertions": [
        { "method": "log_multivariate_beta", "args": [1.0, 1.0, 1.0], "expected": -0.6931471805599453, "mode": "abs", "tol": 1e-10 }
      ]
    }
  ]
}
