{
  "target": "MultivariateNormal",
  "kind": "multivariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Multivariate/Test_MultivariateNormal.cs",
  "reference": "Test_MultivariateNormalDist verified against Accord.NET. The seeded MVNDST/CDF cases (Genz-Bretz quasi-Monte-Carlo, seed 12345) and the curated inverse_cdf/interval/mahalanobis/high-correlation-CDF spot values land with the Task 5 commit that ports MVNDST -- see fixtures/README.md's statefulness contract for MultivariateNormal.",
  "note": "GenerateRandomValues/LatinHypercubeRandomValues/StratifiedRandomValues are not covered here -- seeded sampling gets first-N oracles in a later task (mirrors the Dirichlet/Multinomial/BivariateEmpirical precedent). Clone is not fixture-observable.",
  "cases": [
    {
      "name": "accord_2d_moments_pdf_cdf",
      "construct": { "mean": [4.0, 2.0], "covariance": [[0.3, 0.1], [0.1, 0.7]] },
      "assertions": [
        { "method": "mean", "args": [0], "expected": 4.0, "mode": "abs", "tol": 1e-4 },
        { "method": "mean", "args": [1], "expected": 2.0, "mode": "abs", "tol": 1e-4 },
        { "method": "median", "args": [0], "expected": 4.0, "mode": "abs", "tol": 1e-4 },
        { "method": "median", "args": [1], "expected": 2.0, "mode": "abs", "tol": 1e-4 },
        { "method": "mode", "args": [0], "expected": 4.0, "mode": "abs", "tol": 1e-4 },
        { "method": "mode", "args": [1], "expected": 2.0, "mode": "abs", "tol": 1e-4 },
        { "method": "sd", "args": [0], "expected": 0.5477225575051661, "mode": "abs", "tol": 1e-4 },
        { "method": "sd", "args": [1], "expected": 0.8366600265340756, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [[2.0, 5.0]], "expected": 0.000000018917884164743237, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [[4.0, 2.0]], "expected": 0.35588127170858852, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [[3.0, 7.0]], "expected": 0.000000000036520107734505265, "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [[3.0, 5.0]], "expected": 0.033944035782101548, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "log_pdf_non_finite_input",
      "construct": { "mean": [0.0, 0.0], "covariance": [[1.0, 0.0], [0.0, 1.0]] },
      "assertions": [
        { "method": "log_pdf", "args": [["inf", 0.0]], "expected": "-inf", "mode": "equal" }
      ]
    }
  ]
}
