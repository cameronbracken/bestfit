{
  "target": "GeneralizedExtremeValue",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_GeneralizedExtremeValue.cs",
  "reference": "Rao & Hamed, Flood Frequency Analysis, CRC Press 2000",
  "datasets": {
    "white_river": [23200, 2950, 10300, 23200, 4540, 9960, 10800, 26900, 23300, 20400, 8480, 3150, 9380, 32400, 20800, 11100, 7270, 9600, 14600, 14300, 22500, 14700, 12700, 9740, 3050, 8830, 12000, 30400, 27000, 15200, 8040, 11700, 20300, 22700, 30400, 9180, 4870, 14700, 12800, 13700, 7960, 9830, 12500, 10700, 13200, 14700, 14300, 4050, 14600, 14400, 19200, 7160, 12100, 8650, 10600, 24500, 14400, 6300, 9560, 15800, 14300, 28700],
    "lmom_sample": [1953, 1939, 1677, 1692, 2051, 2371, 2022, 1521, 1448, 1825, 1363, 1760, 1672, 1603, 1244, 1521, 1783, 1560, 1357, 1673, 1625, 1425, 1688, 1577, 1736, 1640, 1584, 1293, 1277, 1742, 1491]
  },
  "cases": [
    {
      "name": "default_moments_and_functions",
      "construct": { "params": [100, 10, 0] },
      "assertions": [
        { "method": "mean",     "args": [],     "expected": 105.77215664901533, "mode": "abs", "tol": 1e-6 },
        { "method": "median",   "args": [],     "expected": 103.66512,          "mode": "abs", "tol": 1e-4 },
        { "method": "mode",     "args": [],     "expected": 100,                "mode": "abs", "tol": 1e-9 },
        { "method": "sd",       "args": [],     "expected": 12.825498,          "mode": "abs", "tol": 1e-5 },
        { "method": "skewness", "args": [],     "expected": 1.1396,             "mode": "abs", "tol": 1e-9 },
        { "method": "kurtosis", "args": [],     "expected": 5.4,                "mode": "abs", "tol": 1e-9 },
        { "method": "minimum",  "args": [],     "expected": "-inf",             "mode": "equal" },
        { "method": "maximum",  "args": [],     "expected": "inf",              "mode": "equal" },
        { "method": "pdf",      "args": [0],    "expected": 0,                  "mode": "equal" },
        { "method": "pdf",      "args": [1],    "expected": 0,                  "mode": "equal" },
        { "method": "cdf",      "args": [100],  "expected": 0.367879,           "mode": "abs", "tol": 1e-4 },
        { "method": "cdf",      "args": [200],  "expected": 0.9999546,          "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0.5],  "expected": 103.66512,          "mode": "abs", "tol": 1e-5 },
        { "method": "quantile", "args": [0],    "expected": "-inf",             "mode": "equal" },
        { "method": "quantile", "args": [1],    "expected": "inf",              "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true,           "mode": "bool" }
      ]
    },
    {
      "name": "shape_0p9",
      "construct": { "params": [100, 10, 0.9] },
      "assertions": [
        { "method": "mean",   "args": [], "expected": 100.42482,   "mode": "abs", "tol": 1e-4 },
        { "method": "median", "args": [], "expected": 104.3419519, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "shape_1_bounded",
      "construct": { "params": [100, 10, 1] },
      "assertions": [
        { "method": "mode",     "args": [],    "expected": 95,                   "mode": "abs", "tol": 1e-9 },
        { "method": "maximum",  "args": [],    "expected": 110,                  "mode": "abs", "tol": 1e-9 },
        { "method": "pdf",      "args": [0],   "expected": 1.67017007902456e-06, "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [100], "expected": 0.367879,             "mode": "abs", "tol": 1e-5 },
        { "method": "cdf",      "args": [200], "expected": 1,                    "mode": "equal" },
        { "method": "sd",       "args": [],    "expected": "nan",                "mode": "equal" },
        { "method": "skewness", "args": [],    "expected": "nan",                "mode": "equal" },
        { "method": "kurtosis", "args": [],    "expected": "nan",                "mode": "equal" }
      ]
    },
    {
      "name": "sd_shape_0p49",
      "construct": { "params": [100, 10, 0.49] },
      "assertions": [
        { "method": "sd", "args": [], "expected": 9.280898, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "skewness_shape_0p3",
      "construct": { "params": [100, 10, 0.3] },
      "assertions": [
        { "method": "skewness", "args": [], "expected": -0.0690175, "mode": "abs", "tol": 1e-3 }
      ]
    },
    {
      "name": "kurtosis_shape_0p24",
      "construct": { "params": [100, 10, 0.24] },
      "assertions": [
        { "method": "kurtosis", "args": [], "expected": 2.7659607, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "mean_undefined_large_shape",
      "construct": { "params": [100, 10, 10] },
      "assertions": [
        { "method": "mean", "args": [], "expected": "nan", "mode": "equal" }
      ]
    },
    {
      "name": "minimum_negative_shape",
      "construct": { "params": [100, 10, -5] },
      "assertions": [
        { "method": "minimum", "args": [], "expected": 98, "mode": "abs", "tol": 1e-9 }
      ]
    },
    {
      "name": "invalid_parameters",
      "construct": { "params": ["nan", "nan", "nan"] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "invalid_parameters_inf",
      "construct": { "params": ["inf", "inf", "inf"] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "invalid_parameters_zero_scale",
      "construct": { "params": [100, 0, 1] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "mom_fit",
      "construct": { "fit": { "dataset": "white_river", "method": "mom" } },
      "assertions": [
        { "method": "param", "args": ["location"], "expected": 11012,  "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": ["scale"],    "expected": 6209.4, "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": ["shape"],    "expected": 0.0736, "mode": "rel", "tol": 0.01 }
      ]
    },
    {
      "name": "lmom_fit",
      "construct": { "fit": { "dataset": "lmom_sample", "method": "lmom" } },
      "assertions": [
        { "method": "param",         "args": ["location"], "expected": 1543.933,  "mode": "abs", "tol": 0.001 },
        { "method": "param",         "args": ["scale"],    "expected": 218.1148,  "mode": "abs", "tol": 0.001 },
        { "method": "param",         "args": ["shape"],    "expected": 0.1068473, "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [0],          "expected": 1648.806,  "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [1],          "expected": 138.2366,  "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [2],          "expected": 0.1030703, "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [3],          "expected": 0.1277244, "mode": "abs", "tol": 0.001 }
      ]
    },
    {
      "name": "mle_fit",
      "construct": { "fit": { "dataset": "white_river", "method": "mle" } },
      "assertions": [
        { "method": "param", "args": ["location"], "expected": 10849,  "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": ["scale"],    "expected": 5745.6, "mode": "rel", "tol": 0.01 }
      ]
    },
    {
      "name": "quantile_roundtrip",
      "construct": { "params": [10849, 5745.6, 0.005] },
      "assertions": [
        { "method": "quantile", "args": [0.99], "expected": 36977, "mode": "rel", "tol": 0.01 }
      ]
    },
    {
      "name": "standard_error",
      "construct": { "params": [10849, 5745.6, 0.005] },
      "assertions": [
        { "method": "quantile_gradient",    "args": [0.99, 0],    "expected": 1.0,       "mode": "rel", "tol": 0.01 },
        { "method": "quantile_gradient",    "args": [0.99, 1],    "expected": 4.5472,    "mode": "rel", "tol": 0.01 },
        { "method": "quantile_gradient",    "args": [0.99, 2],    "expected": -59861,    "mode": "rel", "tol": 0.01 },
        { "method": "parameter_covariance", "args": [62, 0, 0],   "expected": 664669,    "mode": "rel", "tol": 0.01 },
        { "method": "parameter_covariance", "args": [62, 1, 1],   "expected": 346400,    "mode": "rel", "tol": 0.01 },
        { "method": "parameter_covariance", "args": [62, 2, 2],   "expected": 0.007655,  "mode": "rel", "tol": 0.01 },
        { "method": "parameter_covariance", "args": [62, 0, 1],   "expected": 176180,    "mode": "rel", "tol": 0.01 },
        { "method": "parameter_covariance", "args": [62, 0, 2],   "expected": 23.977,    "mode": "rel", "tol": 0.01 },
        { "method": "parameter_covariance", "args": [62, 1, 2],   "expected": 13.8574,   "mode": "rel", "tol": 0.01 },
        { "method": "quantile_variance",    "args": [0.99, 62],   "expected": 26445364,  "mode": "rel", "tol": 0.01 },
        { "method": "quantile_se",          "args": [0.99, 62],   "expected": 5142,      "mode": "rel", "tol": 0.01 }
      ]
    }
  ]
}
