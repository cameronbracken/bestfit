103000, 134000, 71700, 57000, 63900, 60700, 81900, 171000, 111000, 50400, 50500, 69700, 88900, 76600],
    "lmom_sample": [1953, 1939, 1677, 1692, 2051, 2371, 2022, 1521, 1448, 1825, 1363, 1760, 1672, 1603, 1244, 1521, 1783, 1560, 1357, 1673, 1625, 1425, 1688, 1577, 1736, 1640, 1584, 1293, 1277, 1742, 1491]
  },
  "cases": [
    {
      "name": "kappa_zero_limit_branch",
      "comment": "kappa=0 exercises the near-zero branch: exponential distribution on [xi, inf)",
      "construct": { "params": [0.0, 1.0, 0.0] },
      "assertions": [
        { "method": "pdf",      "args": [0.0],  "expected": 1.0,                  "mode": "abs", "tol": 1e-12 },
        { "method": "pdf",      "args": [1.0],  "expected": 0.36787944117144233,  "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [0.0],  "expected": 0.0,                  "mode": "equal" },
        { "method": "cdf",      "args": [1.0],  "expected": 0.6321205588285578,   "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.0],  "expected": 0.0,                  "mode": "equal" },
        { "method": "quantile", "args": [0.5],  "expected": 0.6931471805599453,   "mode": "abs", "tol": 1e-9 },
        { "method": "quantile", "args": [1.0],  "expected": "inf",                "mode": "equal" },
        { "method": "mean",     "args": [],     "expected": 1.0,                  "mode": "equal" },
        { "method": "median",   "args": [],     "expected": 0.6931471805599453,   "mode": "abs", "tol": 1e-12 },
        { "method": "mode",     "args": [],     "expected": 0.0,                  "mode": "equal" },
        { "method": "sd",       "args": [],     "expected": 1.0,                  "mode": "equal" },
        { "method": "skewness", "args": [],     "expected": 2.0,                  "mode": "equal" },
        { "method": "kurtosis", "args": [],     "expected": 9.0,                  "mode": "equal" },
        { "method": "minimum",  "args": [],     "expected": 0.0,                  "mode": "equal" },
        { "method": "maximum",  "args": [],     "expected": "inf",                "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true,             "mode": "bool" }
      ]
    },
    {
      "name": "default_100_10_0",
      "comment": "default constructor params: xi=100, alpha=10, kappa=0",
      "construct": { "params": [100.0, 10.0, 0.0] },
      "assertions": [
        { "method": "pdf",      "args": [100.0], "expected": 0.1,                   "mode": "abs", "tol": 1e-12 },
        { "method": "pdf",      "args": [200.0], "expected": 4.53999297624849e-06,  "mode": "rel", "tol": 1e-6 },
        { "method": "cdf",      "args": [100.0], "expected": 0.0,                   "mode": "equal" },
        { "method": "cdf",      "args": [200.0], "expected": 0.9999546000702376,    "mode": "abs", "tol": 1e-9 },
        { "method": "mean",     "args": [],      "expected": 110.0,                 "mode": "equal" },
        { "method": "median",   "args": [],      "expected": 106.931471805599453,   "mode": "abs", "tol": 1e-4 },
        { "method": "mode",     "args": [],      "expected": 100.0,                 "mode": "equal" },
        { "method": "sd",       "args": [],      "expected": 10.0,                  "mode": "equal" },
        { "method": "minimum",  "args": [],      "expected": 100.0,                 "mode": "equal" },
        { "method": "maximum",  "args": [],      "expected": "inf",                 "mode": "equal" }
      ]
    },
    {
      "name": "positive_kappa_bounded",
      "comment": "xi=100, alpha=10, kappa=1: bounded above at xi+alpha/kappa=110",
      "construct": { "params": [100.0, 10.0, 1.0] },
      "assertions": [
        { "method": "mean",     "args": [],      "expected": "nan",  "mode": "equal" },
        { "method": "sd",       "args": [],      "expected": "nan",  "mode": "equal" },
        { "method": "skewness", "args": [],      "expected": "nan",  "mode": "equal" },
        { "method": "kurtosis", "args": [],      "expected": "nan",  "mode": "equal" },
        { "method": "minimum",  "args": [],      "expected": 100.0,  "mode": "equal" },
        { "method": "maximum",  "args": [],      "expected": 110.0,  "mode": "equal" },
        { "method": "cdf",      "args": [50.0],  "expected": 0.0,    "mode": "equal" },
        { "method": "cdf",      "args": [200.0], "expected": 1.0,    "mode": "equal" },
        { "method": "pdf",      "args": [50.0],  "expected": 0.0,    "mode": "equal" },
        { "method": "quantile", "args": [0.3],   "expected": 103.0,  "mode": "abs",  "tol": 1e-9 },
        { "method": "median",   "args": [],      "expected": 95.0,   "mode": "abs",  "tol": 1e-9 }
      ]
    },
    {
      "name": "negative_kappa_moments",
      "comment": "xi=100, alpha=10, kappa=-0.1: all moments exist, unbounded above",
      "construct": { "params": [100.0, 10.0, -0.1] },
      "assertions": [
        { "method": "mean",     "args": [],  "expected": 111.111111111111,     "mode": "abs", "tol": 1e-6 },
        { "method": "sd",       "args": [],  "expected": 12.422599874998830,   "mode": "abs", "tol": 1e-6 },
        { "method": "skewness", "args": [],  "expected": 2.811056885999736,    "mode": "abs", "tol": 1e-6 },
        { "method": "minimum",  "args": [],  "expected": 100.0,                "mode": "equal" },
        { "method": "maximum",  "args": [],  "expected": "inf",                "mode": "equal" }
      ]
    },
    {
      "name": "invalid_nan",
      "construct": { "params": ["nan", "nan", "nan"] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "invalid_zero_scale",
      "construct": { "params": [100.0, 0.0, 1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "lmom_fit",
      "construct": { "fit": { "dataset": "lmom_sample", "method": "lmom" } },
      "assertions": [
        { "method": "param",         "args": [0], "expected": 1285.909,   "mode": "abs", "tol": 0.001 },
        { "method": "param",         "args": [1], "expected": 589.7772,   "mode": "abs", "tol": 0.001 },
        { "method": "param",         "args": [2], "expected": 0.6251903,  "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [0], "expected": 1648.806,   "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [1], "expected": 138.2366,   "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [2], "expected": 0.1033903,  "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [3], "expected": 0.03073215, "mode": "abs", "tol": 0.001 }
      ]
    },
    {
      "name": "mle_fit",
      "construct": { "fit": { "dataset": "white_river", "method": "mle" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 50400.0,  "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": [1], "expected": 55142.29, "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": [2], "expected": 0.0945,   "mode": "rel", "tol": 0.05 }
      ]
    }
  ]
}
