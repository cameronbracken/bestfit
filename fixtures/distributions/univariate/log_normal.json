{
  "target": "LogNormal",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_LogNormal.cs",
  "reference": "Rao & Hamed, Flood Frequency Analysis, CRC Press 2000",
  "datasets": {
    "wind_data": [7.4, 8.0, 12.6, 11.5, 14.3, 14.9, 8.6, 13.8, 20.1, 8.6, 6.9, 9.7, 9.2, 10.9, 13.2, 11.5, 12.0, 18.4, 11.5, 9.7, 9.7, 16.6, 9.7, 12.0, 16.6, 14.9, 8.0, 12.0, 14.9, 5.7, 7.4, 8.6, 9.7, 16.1, 9.2, 8.6, 14.3, 9.7, 6.9, 13.8, 11.5, 10.9, 9.2, 8.0, 13.8, 11.5, 14.9, 20.7, 9.2, 11.5, 10.3, 6.3, 1.7, 4.6, 6.3, 8.0, 8.0, 10.3, 11.5, 14.9, 8.0, 4.1, 9.2, 9.2, 10.9, 4.6, 10.9, 5.1, 6.3, 5.7, 7.4, 8.6, 14.3, 14.9, 14.9, 14.3, 6.9, 10.3, 6.3, 5.1, 11.5, 6.9, 9.7, 11.5, 8.6, 8.0, 8.6, 12.0, 7.4, 7.4, 7.4, 9.2, 6.9, 13.8, 7.4, 6.9, 7.4, 4.6, 4.0, 10.3, 8.0, 8.6, 11.5, 11.5, 11.5, 9.7, 11.5, 10.3, 6.3, 7.4, 10.9, 10.3, 15.5, 14.3, 12.6, 9.7, 3.4, 8.0, 5.7, 9.7, 2.3, 6.3, 6.3, 6.9, 5.1, 2.8, 4.6, 7.4, 15.5, 10.9, 10.3, 10.9, 9.7, 14.9, 15.5, 6.3, 10.9, 11.5, 6.9, 13.8, 10.3, 10.3, 8.0, 12.6, 9.2, 10.3, 10.3, 16.6, 6.9, 13.2, 14.3, 8.0, 11.5]
  },
  "cases": [
    {
      "name": "standard_pdf_cdf_moments",
      "construct": { "params": [3.0, 0.5] },
      "assertions": [
        { "method": "pdf",      "args": [1000.0], "expected": 0.000346516861952484, "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [1000.0], "expected": 0.5, "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.5], "expected": 1000.0, "mode": "abs", "tol": 1e-6 },
        { "method": "mean",     "args": [], "expected": 1940.0956263817814, "mode": "abs", "tol": 1e-6 },
        { "method": "median",   "args": [], "expected": 1000.0, "mode": "abs", "tol": 1e-6 },
        { "method": "mode",     "args": [], "expected": 1000.0, "mode": "abs", "tol": 1e-6 },
        { "method": "sd",       "args": [], "expected": 3225.4467824988237, "mode": "abs", "tol": 1e-6 },
        { "method": "skewness", "args": [], "expected": 9.582714166756007, "mode": "abs", "tol": 1e-6 },
        { "method": "kurtosis", "args": [], "expected": 346.87182013531077, "mode": "abs", "tol": 1e-3 },
        { "method": "minimum",  "args": [], "expected": 0.0, "mode": "equal" },
        { "method": "maximum",  "args": [], "expected": "inf", "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "cdf_test",
      "construct": { "params": [1.5, 1.5] },
      "assertions": [
        { "method": "cdf",      "args": [0.5], "expected": 0.1149363846234025, "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "quantile_test",
      "construct": { "params": [2.5, 2.5] },
      "assertions": [
        { "method": "quantile", "args": [0.8], "expected": 40183.99248502478, "mode": "abs", "tol": 0.01 }
      ]
    },
    {
      "name": "invalid_nan",
      "construct": { "params": ["nan", "nan"] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "invalid_neg_sigma",
      "construct": { "params": [1.0, -1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "lmom_fit",
      "construct": { "fit": { "dataset": "wind_data", "method": "lmom" } },
      "assertions": [
        { "method": "param",         "args": [0], "expected": 0.9672391,   "mode": "abs", "tol": 0.0001 },
        { "method": "param",         "args": [1], "expected": 0.1675344,   "mode": "abs", "tol": 0.0001 },
        { "method": "linear_moment", "args": [0], "expected": 0.96723909,  "mode": "abs", "tol": 0.0001 },
        { "method": "linear_moment", "args": [1], "expected": 0.09452119,  "mode": "abs", "tol": 0.0001 },
        { "method": "linear_moment", "args": [2], "expected": 0.0,         "mode": "abs", "tol": 0.0001 },
        { "method": "linear_moment", "args": [3], "expected": 0.12260172,  "mode": "abs", "tol": 0.0001 }
      ]
    },
    {
      "name": "seeded_random_draws",
      "source": "curated via oracle_emitter --dump (GenerateRandomValues(sampleSize, seed))",
      "construct": { "params": [3.0, 0.5] },
      "assertions": [
        { "method": "random_value", "args": [50, 123, 0], "expected": 1807.7407580366632, "mode": "rel", "tol": 1e-11 },
        { "method": "random_value", "args": [50, 123, 1], "expected": 1909.9393057551188, "mode": "rel", "tol": 1e-11 },
        { "method": "random_value", "args": [50, 123, 2], "expected": 521.9761019068768, "mode": "rel", "tol": 1e-11 },
        { "method": "random_value", "args": [50, 123, 49], "expected": 786.1073291848488, "mode": "rel", "tol": 1e-11 }
      ]
    }
  ]
}
