        { "method": "quantile", "args": [0.95],  "expected": 112.12362757263723,  "mode": "abs", "tol": 1e-4  },
        { "method": "mean",     "args": [],       "expected": 96.729020376712626,  "mode": "abs", "tol": 1e-2  },
