    {
      "name": "two_normal_perfectly_negative_min_rule",
      "construct": {
        "components": [
          {"target": "Normal", "params": [100.0, 10.0]},
          {"target": "Normal", "params": [110.0, 15.0]}
        ],
        "minimum_of_random_variables": true,
        "dependency": "PerfectlyNegative"
      },
      "assertions": [
        { "method": "cdf", "args": [80.0], "expected": 0.04550026389635842,   "mode": "abs", "tol": 1e-9, "source": "curated via oracle_emitter --dump" },
        { "method": "cdf", "args": [90.0], "expected": 0.249866473657325,     "mode": "abs", "tol": 1e-9, "source": "curated via oracle_emitter --dump" },
        { "method": "cdf", "args": [98.0], "expected": 0.6325956891442938,    "mode": "abs", "tol": 1e-9, "source": "curated via oracle_emitter --dump" },
        { "method": "pdf", "args": [80.0], "expected": 0.008998494402689586,  "mode": "abs", "tol": 1e-6, "source": "curated via oracle_emitter --dump" },
        { "method": "pdf", "args": [90.0], "expected": 0.035131077363116915,  "mode": "abs", "tol": 1e-6, "source": "curated via oracle_emitter --dump" },
        { "method": "pdf", "args": [98.0], "expected": 0.058417039690600504,  "mode": "abs", "tol": 1e-6, "source": "curated via oracle_emitter --dump" },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
