{
  "target": "ChiSquared",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_ChiSquared.cs",
  "cases": [
    {
      "name": "dof7_moments_pdf_cdf_quantile",
      "construct": { "params": [7.0] },
      "assertions": [
        { "method": "mean",             "args": [],        "expected": 7.0,                     "mode": "abs", "tol": 0.0001 },
        { "method": "median",           "args": [],        "expected": 6.345811195595612,        "mode": "abs", "tol": 0.0001 },
        { "method": "sd",               "args": [],        "expected": 3.7416573867739413,       "mode": "abs", "tol": 0.0001 },
        { "method": "pdf",              "args": [6.27],    "expected": 0.11388708001184455,      "mode": "abs", "tol": 0.0001 },
        { "method": "cdf",              "args": [6.27],    "expected": 0.49139966433823956,      "mode": "abs", "tol": 0.0001 },
        { "method": "quantile",         "args": [0.49139966433823956], "expected": 6.27,         "mode": "abs", "tol": 0.0001 },
        { "method": "parameters_valid", "args": [],        "expected": true,                     "mode": "bool" }
      ]
    },
    {
      "name": "dof1_pdf_cdf",
      "construct": { "params": [1.0] },
      "assertions": [
        { "method": "pdf", "args": [0.1],  "expected": 1.2000389,  "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [1.0],  "expected": 0.2419707,  "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [5.5],  "expected": 0.0108747,  "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [0.1],  "expected": 0.2481703,  "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [1.0],  "expected": 0.682689,   "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [5.5],  "expected": 0.9809835,  "mode": "abs", "tol": 1e-4 },
        { "method": "mode",             "args": [], "expected": 0.0, "mode": "abs", "tol": 1e-12 },
        { "method": "skewness",         "args": [], "expected": 2.8284271247461903, "mode": "abs", "tol": 1e-4 },
        { "method": "kurtosis",         "args": [], "expected": 15.0, "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "dof2_pdf_cdf_moments",
      "construct": { "params": [2.0] },
      "assertions": [
        { "method": "pdf", "args": [0.0],  "expected": 0.5,        "mode": "abs", "tol": 1e-12 },
        { "method": "pdf", "args": [0.1],  "expected": 0.4756147,  "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [1.0],  "expected": 0.3032653,  "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [5.5],  "expected": 0.0319639,  "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [0.0],  "expected": 0.0,        "mode": "abs", "tol": 1e-12 },
        { "method": "cdf", "args": [0.1],  "expected": 0.04877057, "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [1.0],  "expected": 0.3934693,  "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [5.5],  "expected": 0.9360721,  "mode": "abs", "tol": 1e-4 },
        { "method": "mean",     "args": [], "expected": 2.0,        "mode": "abs", "tol": 1e-12 },
        { "method": "sd",       "args": [], "expected": 2.0,        "mode": "abs", "tol": 1e-12 },
        { "method": "skewness", "args": [], "expected": 2.0,        "mode": "abs", "tol": 1e-12 },
        { "method": "mode",     "args": [], "expected": 0.0,        "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "dof1_quantile",
      "construct": { "params": [1.0] },
      "assertions": [
        { "method": "quantile", "args": [0.24817036595415071751], "expected": 0.09999, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.68268949213708589717], "expected": 1.0,     "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.9809835],              "expected": 5.5,     "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "dof2_quantile",
      "construct": { "params": [2.0] },
      "assertions": [
        { "method": "quantile", "args": [0.0],        "expected": 0.0, "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.04877057], "expected": 0.1, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.3934693],  "expected": 1.0, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.9360721],  "expected": 5.5, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "dof5_mode",
      "construct": { "params": [5.0] },
      "assertions": [
        { "method": "mode", "args": [], "expected": 3.0, "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "dof3_kurtosis",
      "construct": { "params": [3.0] },
      "assertions": [
        { "method": "kurtosis", "args": [], "expected": 7.0, "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "large_dof_pdf",
      "construct": { "params": [100.0] },
      "assertions": [
        { "method": "pdf", "args": [100.0], "expected": 0.028162503163, "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "large_dof_pdf_500",
      "construct": { "params": [500.0] },
      "assertions": [
        { "method": "pdf", "args": [500.0], "expected": 0.012611458093, "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "large_dof_cdf_large_x",
      "construct": { "params": [10.0] },
      "assertions": [
        { "method": "cdf", "args": [110.0], "expected": 1.0, "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "invalid_params_dof0",
      "construct": { "params": [0.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "invalid_nan_dof",
      "note": "v2.1.4: ValidateParameters now rejects NaN/Infinity explicitly (previously only `dof < 1.0d` on the ALREADY TRUNCATED value, false for both NaN and +Infinity -- see chi_squared.hpp file header note).",
      "construct": { "params": ["nan"] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "invalid_inf_dof",
      "construct": { "params": ["inf"] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "minimum_maximum",
      "construct": { "params": [1.0] },
      "assertions": [
        { "method": "minimum", "args": [], "expected": 0.0, "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.0], "expected": 0.0, "mode": "abs", "tol": 1e-12 }
      ]
    }
  ]
}
