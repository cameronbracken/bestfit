      ]
    },
    {
      "name": "lmom_forward_signed_small_skew_positive",
      "comment": "Mirrors Test_LinearMoments_SignedSmallAndZeroSkew (positive branch); alpha=4/gamma^2=400 exercises the alpha>=100 Stirling branch (retiring the earlier one-sided intentional divergence -- see docs/upstream-csharp-issues.md).",
      "construct": { "params": [2.0, 0.3, 0.1] },
      "assertions": [
        { "method": "linear_moment", "args": [0], "expected": 2.0,                   "mode": "abs", "tol": 1e-14 },
        { "method": "linear_moment", "args": [1], "expected": 0.16920399055536514,   "mode": "abs", "tol": 1e-13 },
        { "method": "linear_moment", "args": [2], "expected": 0.016288820701197349,  "mode": "abs", "tol": 1e-13 },
        { "method": "linear_moment", "args": [3], "expected": 0.12267996090847449,   "mode": "abs", "tol": 1e-13 }
      ]
    },
    {
      "name": "lmom_forward_signed_small_skew_negative",
      "comment": "Mirrors Test_LinearMoments_SignedSmallAndZeroSkew (negative branch): same L1/L2/T4 as the positive-skew twin, T3 opposite sign (the SIGNED L-skewness fix -- v2.1.4 resolves docs/upstream-csharp-issues.md's PearsonTypeIII/LogPearsonTypeIII L-skewness-sign entry).",
      "construct": { "params": [2.0, 0.3, -0.1] },
      "assertions": [
        { "method": "linear_moment", "args": [0], "expected": 2.0,                   "mode": "abs", "tol": 1e-14 },
        { "method": "linear_moment", "args": [1], "expected": 0.16920399055536514,   "mode": "abs", "tol": 1e-13 },
        { "method": "linear_moment", "args": [2], "expected": -0.016288820701197349, "mode": "abs", "tol": 1e-13 },
        { "method": "linear_moment", "args": [3], "expected": 0.12267996090847449,   "mode": "abs", "tol": 1e-13 }
      ]
    },
    {
      "name": "lmom_reverse_zero_skew_fit",
      "comment": "log10_exact_1to8's raw values were chosen so log(v)/log(10) (the port's transform_log, matching C#) reproduces exactly {1,...,8} bit-for-bit -- an evenly-spaced sequence whose sample L-skewness (T3) is bit-exact 0.0, hitting ParametersFromLinearMoments' new T3==0 early-return branch through a real fit.",
      "construct": { "fit": { "method": "lmom", "dataset": "log10_exact_1to8" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 4.5,                 "mode": "abs", "tol": 1e-13 },
        { "method": "param", "args": [1], "expected": 2.658680776358274,   "mode": "abs", "tol": 1e-12 },
        { "method": "param", "args": [2], "expected": 0.0,                 "mode": "abs", "tol": 0.0 },
        { "method": "linear_moment", "args": [0], "expected": 4.5,         "mode": "abs", "tol": 1e-13 },
        { "method": "linear_moment", "args": [1], "expected": 1.5,         "mode": "abs", "tol": 1e-12 },
        { "method": "linear_moment", "args": [2], "expected": 0.0,         "mode": "abs", "tol": 0.0 }
      ]
