    {
      "name": "lmom_forward_zero_skew",
      "comment": "v2.1.4 gamma==0 exact Normal limit: [mu, sigma/sqrt(pi), 0, 0.12260172] (same code path as PearsonTypeIII).",
      "construct": { "params": [2.0, 0.3, 0.0] },
      "assertions": [
        { "method": "linear_moment", "args": [0], "expected": 2.0,                  "mode": "abs", "tol": 1e-14 },
        { "method": "linear_moment", "args": [1], "expected": 0.16925687506432691,  "mode": "abs", "tol": 1e-14 },
        { "method": "linear_moment", "args": [2], "expected": 0.0,                  "mode": "abs", "tol": 0.0 },
