{
  "target": "NoncentralT",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_NoncentralT.cs",
  "cases": [
    {
      "name": "nct_default_nu10_lambda0_moments",
      "note": "Default constructor NCT(10,0): Test_Construction, Test_Mean, Test_StandardDeviation, Test_Skewness, Test_Kurtosis, Test_CDF, Test_InverseCDF, Test_MinMax",
      "construct": { "params": [10.0, 0.0] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 0.0,                   "mode": "abs", "tol": 1e-12 },
        { "method": "median",   "args": [], "expected": 0.0,                   "mode": "abs", "tol": 1e-4 },
        { "method": "mode",     "args": [], "expected": 0.0,                   "mode": "abs", "tol": 1e-4 },
        { "method": "sd",       "args": [], "expected": 1.118033988749895,     "mode": "abs", "tol": 1e-8 },
        { "method": "skewness", "args": [], "expected": 0.0,                   "mode": "abs", "tol": 1e-4 },
        { "method": "kurtosis", "args": [], "expected": 4.0,                   "mode": "abs", "tol": 1e-4 },
        { "method": "pdf",      "args": [0.0], "expected": 0.389108383966031,  "mode": "abs", "tol": 1e-6 },
        { "method": "pdf",      "args": [1.0], "expected": 0.23036198922920748,"mode": "abs", "tol": 1e-6 },
        { "method": "cdf",      "args": [0.0], "expected": 0.5,                "mode": "abs", "tol": 1e-9 },
        { "method": "cdf",      "args": [1.0], "expected": 0.82955343384897,   "mode": "abs", "tol": 1e-6 },
        { "method": "quantile", "args": [0.4],  "expected": -0.2601848294945007, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.0],  "expected": "-inf", "mode": "equal" },
        { "method": "quantile", "args": [1.0],  "expected": "inf",  "mode": "equal" },
        { "method": "minimum",  "args": [], "expected": "-inf", "mode": "equal" },
        { "method": "maximum",  "args": [], "expected": "inf",  "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "nct_nu4_lambda2p42_pdf_cdf",
      "note": "Test_NoncentralT_PDF and Test_NoncentralT_CDF: NCT(4, 2.42) at x=1.4",
      "construct": { "params": [4.0, 2.42] },
      "assertions": [
        { "method": "pdf",      "args": [1.4], "expected": 0.23552141805184526, "mode": "abs", "tol": 1e-6 },
        { "method": "cdf",      "args": [1.4], "expected": 0.15955740661144721, "mode": "abs", "tol": 1e-6 },
        { "method": "quantile", "args": [0.15955740661144721], "expected": 1.4,  "mode": "abs", "tol": 1e-4 },
        { "method": "mean",     "args": [], "expected": 3.0330202123035104,    "mode": "abs", "tol": 1e-6 },
        { "method": "sd",       "args": [], "expected": 2.124520744016958,     "mode": "abs", "tol": 1e-6 },
        { "method": "median",   "args": [], "expected": 2.603484241402926,     "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "nct_nu1_lambda0_undefined_moments",
      "note": "nu=1 -> mean and sd are NaN; Test_Mean, Test_StandardDeviation",
      "construct": { "params": [1.0, 0.0] },
      "assertions": [
        { "method": "mean", "args": [], "expected": "nan", "mode": "equal" },
        { "method": "sd",   "args": [], "expected": "nan", "mode": "equal" }
      ]
    },
    {
      "name": "nct_nu1_lambda1_median",
      "note": "Test_Median: NCT(1,1) median = 1.3202 to 1e-4",
      "construct": { "params": [1.0, 1.0] },
      "assertions": [
        { "method": "median", "args": [], "expected": 1.3202131004036737, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "nct_nu10_lambda1_mode_mean_sd",
      "note": "Test_Mode, mean, sd for NCT(10,1)",
      "construct": { "params": [10.0, 1.0] },
      "assertions": [
        { "method": "mode", "args": [], "expected": 0.9329103356403101, "mode": "abs", "tol": 1e-4 },
        { "method": "mean", "args": [], "expected": 1.0837223079391438, "mode": "abs", "tol": 1e-6 },
        { "method": "sd",   "args": [], "expected": 1.1513235684528724, "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "nct_lambda0_reduces_to_central_t",
      "note": "lambda=0: NCT(3,0) matches StudentT(0,1,3) to 1e-10; confirms series reduction",
      "construct": { "params": [3.0, 0.0] },
      "assertions": [
        { "method": "cdf",  "args": [0.0],  "expected": 0.5,                   "mode": "abs", "tol": 1e-9 },
        { "method": "pdf",  "args": [0.0],  "expected": 0.3675525969478614,    "mode": "abs", "tol": 1e-6 },
        { "method": "pdf",  "args": [1.0],  "expected": 0.20674833578317453,   "mode": "abs", "tol": 1e-6 },
        { "method": "cdf",  "args": [1.0],  "expected": 0.8044988905221141,    "mode": "abs", "tol": 1e-6 },
        { "method": "cdf",  "args": [-1.0], "expected": 0.1955011094778859,    "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "nct_negative_lambda",
      "note": "Negative noncentrality parameter NCT(5,-2): tests NEGDEL branch in NCTDist",
      "construct": { "params": [5.0, -2.0] },
      "assertions": [
        { "method": "cdf",  "args": [0.0],  "expected": 0.9772498680518208,   "mode": "abs", "tol": 1e-6 },
        { "method": "pdf",  "args": [0.0],  "expected": 0.05137417888564026,  "mode": "abs", "tol": 1e-6 },
        { "method": "cdf",  "args": [-1.0], "expected": 0.8418643565428866,   "mode": "abs", "tol": 1e-6 },
        { "method": "mean", "args": [], "expected": -2.3788321548703615, "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "nct_table_cdf_invcdf_roundtrip",
      "note": "Table values from Test_NoncentralT_InverseCDF: CDF + roundtrip InvCDF",
      "construct": { "params": [1.0, 0.0] },
      "assertions": [
        { "method": "cdf",      "args": [3.0], "expected": 0.89758361765043326, "mode": "abs", "tol": 1e-6 },
        { "method": "quantile", "args": [0.89758361765043326], "expected": 3.0,  "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "nct_table_nu2_lambda0p5",
      "note": "Table: NCT(2, 0.5) CDF at x=3.0",
      "construct": { "params": [2.0, 0.5] },
      "assertions": [
        { "method": "cdf",      "args": [3.0], "expected": 0.9049021509529694, "mode": "abs", "tol": 1e-6 },
        { "method": "quantile", "args": [0.9049021509529694], "expected": 3.0, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "nct_table_nu10_lambda4",
      "note": "Table: NCT(10, 4) CDF at x=5.0; large noncentrality",
      "construct": { "params": [10.0, 4.0] },
      "assertions": [
        { "method": "cdf",      "args": [5.0], "expected": 0.7181904621936699, "mode": "abs", "tol": 1e-6 },
        { "method": "quantile", "args": [0.7181904621936699], "expected": 5.0,  "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "nct_large_df",
      "note": "Large df NCT(100, 2) CDF at x=3",
      "construct": { "params": [100.0, 2.0] },
      "assertions": [
        { "method": "cdf",      "args": [3.0], "expected": 0.8342136564457991, "mode": "abs", "tol": 1e-6 },
        { "method": "quantile", "args": [0.8342136564457991], "expected": 3.0,  "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "nct_invalid_params_nu_too_small",
      "note": "Test_InvalidParameters: nu < 1 -> parameters_valid = false",
      "construct": { "params": [0.0, 1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "nct_invalid_params_lambda_inf",
      "note": "Test_InvalidParameters: lambda = +Inf -> parameters_valid = false",
      "construct": { "params": [1.0, "inf"] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "nct_invalid_params_lambda_nan",
      "construct": { "params": [1.0, "nan"] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "nct_invalid_params_nu_nan",
      "note": "v2.1.4 real fix: the old `v < 1.0d` check is false for NaN, so a NaN degrees-of-freedom silently read as valid before ValidateParameters gained an explicit isnan/isinf check -- see noncentral_t.hpp file header note.",
      "construct": { "params": ["nan", 0.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "nct_invalid_params_nu_inf",
      "note": "v2.1.4 real fix: `Infinity < 1.0d` is also false, so an infinite degrees-of-freedom silently read as valid before this same isnan/isinf check was added.",
      "construct": { "params": ["inf", 0.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    }
  ]
}
