{
  "target": "Triangular",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_Triangular.cs",
  "cases": [
    {
      "name": "default_0_0p5_1",
      "construct": { "params": [0.0, 0.5, 1.0] },
      "assertions": [
        { "method": "mean",     "args": [],       "expected": 0.5,                  "mode": "equal" },
        { "method": "median",   "args": [],       "expected": 0.5,                  "mode": "equal" },
        { "method": "mode",     "args": [],       "expected": 0.5,                  "mode": "equal" },
        { "method": "sd",       "args": [],       "expected": 0.2041241452319315,   "mode": "abs", "tol": 1e-10 },
        { "method": "skewness", "args": [],       "expected": 0.0,                  "mode": "equal" },
        { "method": "kurtosis", "args": [],       "expected": 2.4,                  "mode": "equal" },
        { "method": "minimum",  "args": [],       "expected": 0.0,                  "mode": "equal" },
        { "method": "maximum",  "args": [],       "expected": 1.0,                  "mode": "equal" },
        { "method": "pdf",      "args": [-1.0],   "expected": 0.0,                  "mode": "equal" },
        { "method": "pdf",      "args": [0.4],    "expected": 1.6,                  "mode": "abs", "tol": 1e-12 },
        { "method": "pdf",      "args": [0.5],    "expected": 2.0,                  "mode": "equal" },
        { "method": "pdf",      "args": [0.6],    "expected": 1.6,                  "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [-1.0],   "expected": 0.0,                  "mode": "equal" },
        { "method": "cdf",      "args": [2.0],    "expected": 1.0,                  "mode": "equal" },
        { "method": "cdf",      "args": [0.4],    "expected": 0.32,                 "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [0.6],    "expected": 0.68,                 "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.0],    "expected": 0.0,                  "mode": "equal" },
        { "method": "quantile", "args": [1.0],    "expected": 1.0,                  "mode": "equal" },
        { "method": "quantile", "args": [0.2],    "expected": 0.3162277660168379,   "mode": "abs", "tol": 1e-10 },
        { "method": "quantile", "args": [0.5],    "expected": 0.5,                  "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true,               "mode": "bool" }
      ]
    },
    {
      "name": "params_1_3_6",
      "construct": { "params": [1.0, 3.0, 6.0] },
      "assertions": [
        { "method": "mean",     "args": [],      "expected": 3.3333333333333335,    "mode": "abs", "tol": 1e-10 },
        { "method": "median",   "args": [],      "expected": 3.261387212474169,     "mode": "abs", "tol": 1e-10 },
        { "method": "mode",     "args": [],      "expected": 3.0,                   "mode": "equal" },
        { "method": "sd",       "args": [],      "expected": 1.027402333828163,     "mode": "abs", "tol": 1e-8 },
        { "method": "kurtosis", "args": [],      "expected": 2.4,                   "mode": "equal" },
        { "method": "minimum",  "args": [],      "expected": 1.0,                   "mode": "equal" },
        { "method": "maximum",  "args": [],      "expected": 6.0,                   "mode": "equal" },
        { "method": "pdf",      "args": [2.0],   "expected": 0.2,                   "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [2.0],   "expected": 0.1,                   "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.1],   "expected": 2.0,                   "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "params_0_0p25_1",
      "construct": { "params": [0.0, 0.25, 1.0] },
      "assertions": [
        { "method": "cdf",      "args": [0.1],   "expected": 0.04,                  "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [0.25],  "expected": 0.25,                  "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [0.5],   "expected": 0.6666666666666667,    "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [0.75],  "expected": 0.9166666666666666,    "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [0.9],   "expected": 0.9866666666666667,    "mode": "abs", "tol": 1e-10 },
        { "method": "quantile", "args": [0.04],  "expected": 0.1,                   "mode": "abs", "tol": 1e-10 },
        { "method": "quantile", "args": [0.25],  "expected": 0.25,                  "mode": "abs", "tol": 1e-10 },
        { "method": "quantile", "args": [0.6666666666666667], "expected": 0.5,      "mode": "abs", "tol": 1e-10 },
        { "method": "quantile", "args": [0.9166666666666666], "expected": 0.75,     "mode": "abs", "tol": 1e-10 },
        { "method": "quantile", "args": [0.9866666666666667], "expected": 0.9,      "mode": "abs", "tol": 1e-9 }
      ]
    },
    {
      "name": "invalid_min_gt_max",
      "construct": { "params": [4.0, 1.0, 0.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "invalid_mode_lt_min",
      "construct": { "params": [1.0, 0.0, -1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    }
  ]
}
