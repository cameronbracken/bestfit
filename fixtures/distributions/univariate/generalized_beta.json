{
  "target": "GeneralizedBeta",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_GeneralizedBeta.cs",
  "cases": [
    {
      "name": "alpha0p42_beta1p57_unit",
      "construct": { "params": [0.42, 1.57, 0.0, 1.0] },
      "assertions": [
        { "method": "mean",     "args": [],     "expected": 0.21105527638190955, "mode": "abs", "tol": 1e-4 },
        { "method": "median",   "args": [],     "expected": 0.11577706212908731, "mode": "abs", "tol": 1e-4 },
        { "method": "mode",     "args": [],     "expected": 0.0,                 "mode": "equal" },
        { "method": "sd",       "args": [],     "expected": 0.23598576615025,    "mode": "abs", "tol": 1e-4 },
        { "method": "pdf",      "args": [0.27], "expected": 0.94644031936694828, "mode": "abs", "tol": 1e-4 },
        { "method": "cdf",      "args": [0.27], "expected": 0.69358638272337991, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.69358638272337991], "expected": 0.27, "mode": "abs", "tol": 1e-4 },
        { "method": "param",    "args": [0],    "expected": 0.42,                "mode": "abs", "tol": 1e-12 },
        { "method": "param",    "args": [1],    "expected": 1.57,                "mode": "abs", "tol": 1e-12 },
        { "method": "param",    "args": [2],    "expected": 0.0,                 "mode": "abs", "tol": 1e-12 },
        { "method": "param",    "args": [3],    "expected": 1.0,                 "mode": "abs", "tol": 1e-12 },
        { "method": "parameters_valid", "args": [], "expected": true,            "mode": "bool" }
      ]
    },
    {
      "name": "mode_boundary_decreasing",
      "construct": { "params": [0.42, 1.57, -10.0, 20.0] },
      "assertions": [
        { "method": "mode", "args": [], "expected": -10.0, "mode": "equal" }
      ]
    },
    {
      "name": "mode_boundary_increasing",
      "construct": { "params": [1.57, 0.42, -10.0, 20.0] },
      "assertions": [
        { "method": "mode", "args": [], "expected": 20.0, "mode": "equal" }
      ]
    },
    {
      "name": "mode_boundary_lower",
      "construct": { "params": [0.5, 1.0, -10.0, 20.0] },
      "assertions": [
        { "method": "mode", "args": [], "expected": -10.0, "mode": "equal" }
      ]
    },
    {
      "name": "mode_boundary_upper",
      "construct": { "params": [1.0, 0.5, -10.0, 20.0] },
      "assertions": [
        { "method": "mode", "args": [], "expected": 20.0, "mode": "equal" }
      ]
    },
    {
      "name": "mode_boundary_u_shaped",
      "construct": { "params": [0.5, 0.5, -10.0, 20.0] },
      "assertions": [
        { "method": "mode", "args": [], "expected": 5.0, "mode": "equal" }
      ]
    },
    {
      "name": "alpha1_beta3_unit_R",
      "construct": { "params": [1.0, 3.0, 0.0, 1.0] },
      "assertions": [
        { "method": "cdf",      "args": [0.1],  "expected": 0.271000, "mode": "abs", "tol": 1e-7 },
        { "method": "cdf",      "args": [0.25], "expected": 0.578125, "mode": "abs", "tol": 1e-7 },
        { "method": "cdf",      "args": [0.5],  "expected": 0.875000, "mode": "abs", "tol": 1e-7 },
        { "method": "cdf",      "args": [0.75], "expected": 0.984375, "mode": "abs", "tol": 1e-7 },
        { "method": "cdf",      "args": [0.9],  "expected": 0.999000, "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0.271000], "expected": 0.1,  "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0.578125], "expected": 0.25, "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0.875000], "expected": 0.5,  "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0.984375], "expected": 0.75, "mode": "abs", "tol": 1e-7 },
        { "method": "quantile", "args": [0.999000], "expected": 0.9,  "mode": "abs", "tol": 1e-7 }
      ]
    },
    {
      "name": "mean_2_2_shifted",
      "construct": { "params": [2.0, 2.0, -10.0, 10.0] },
      "assertions": [
        { "method": "mean",    "args": [], "expected": 0.0,      "mode": "abs", "tol": 1e-10 },
        { "method": "mode",    "args": [], "expected": 0.0,      "mode": "abs", "tol": 1e-10 },
        { "method": "sd",      "args": [], "expected": 4.47213,  "mode": "abs", "tol": 1e-4 },
        { "method": "minimum", "args": [], "expected": -10.0,    "mode": "equal" },
        { "method": "maximum", "args": [], "expected": 10.0,     "mode": "equal" }
      ]
    },
    {
      "name": "default_2_2_unit",
      "construct": { "params": [2.0, 2.0, 0.0, 1.0] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 0.5,        "mode": "abs", "tol": 1e-10 },
        { "method": "median",   "args": [], "expected": 0.5,        "mode": "abs", "tol": 1e-6 },
        { "method": "mode",     "args": [], "expected": 0.5,        "mode": "abs", "tol": 1e-10 },
        { "method": "sd",       "args": [], "expected": 0.223606,   "mode": "abs", "tol": 1e-4 },
        { "method": "skewness", "args": [], "expected": 0.0,        "mode": "abs", "tol": 1e-10 },
        { "method": "kurtosis", "args": [], "expected": 2.14285,    "mode": "abs", "tol": 1e-4 },
        { "method": "minimum",  "args": [], "expected": 0.0,        "mode": "equal" },
        { "method": "maximum",  "args": [], "expected": 1.0,        "mode": "equal" }
      ]
    },
    {
      "name": "skew_kurt_cases",
      "construct": { "params": [2.0, 10.0, 0.0, 1.0] },
      "assertions": [
        { "method": "skewness", "args": [], "expected": 0.92140088, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "kurtosis_5_2",
      "construct": { "params": [5.0, 2.0, 0.0, 1.0] },
      "assertions": [
        { "method": "kurtosis", "args": [], "expected": 2.88, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "mode_uniform_case",
      "construct": { "params": [1.0, 1.0, 0.0, 1.0] },
      "assertions": [
        { "method": "mode", "args": [], "expected": 0.5, "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "mode_2_5_case",
      "construct": { "params": [2.0, 5.0, 0.0, 1.0] },
      "assertions": [
        { "method": "mode", "args": [], "expected": 0.2, "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "mode_5_2_case",
      "construct": { "params": [5.0, 2.0, 0.0, 1.0] },
      "assertions": [
        { "method": "mode", "args": [], "expected": 0.8, "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "pdf_1_1_shifted",
      "construct": { "params": [1.0, 1.0, 0.0, 2.0] },
      "assertions": [
        { "method": "pdf", "args": [0.0], "expected": 0.5, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [0.5], "expected": 0.5, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [1.0], "expected": 0.5, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "pdf_cdf_9_1_unit",
      "construct": { "params": [9.0, 1.0, 0.0, 1.0] },
      "assertions": [
        { "method": "pdf", "args": [0.0], "expected": 0.0,         "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [0.5], "expected": 0.035156,    "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [1.0], "expected": 8.9999,      "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [-1.0],"expected": 0.0,         "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [2.0], "expected": 0.0,         "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [0.0], "expected": 0.0,         "mode": "equal" },
        { "method": "cdf", "args": [0.5], "expected": 0.001953125, "mode": "abs", "tol": 1e-9 },
        { "method": "cdf", "args": [1.0], "expected": 1.0,         "mode": "equal" }
      ]
    },
    {
      "name": "cdf_bounds_shifted",
      "construct": { "params": [2.0, 2.0, -10.0, 10.0] },
      "assertions": [
        { "method": "cdf", "args": [-11.0], "expected": 0.0, "mode": "equal" },
        { "method": "cdf", "args": [11.0],  "expected": 1.0, "mode": "equal" }
      ]
    },
    {
      "name": "inverse_cdf_bounds_9_1_shifted",
      "construct": { "params": [9.0, 1.0, -10.0, 10.0] },
      "assertions": [
        { "method": "quantile", "args": [0.0], "expected": -10.0, "mode": "equal" },
        { "method": "quantile", "args": [1.0], "expected": 10.0,  "mode": "equal" }
      ]
    },
    {
      "name": "invalid_min_ge_max",
      "construct": { "params": [1.0, 1.0, 1.0, 0.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    }
  ]
}
