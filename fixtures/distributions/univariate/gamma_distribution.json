{
  "target": "GammaDistribution",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_GammaDistribution.cs",
  "datasets": {
    "wind": [7.4, 8.0, 12.6, 11.5, 14.3, 14.9, 8.6, 13.8, 20.1, 8.6, 6.9, 9.7, 9.2, 10.9, 13.2, 11.5, 12.0, 18.4, 11.5, 9.7, 9.7, 16.6, 9.7, 12.0, 16.6, 14.9, 8.0, 12.0, 14.9, 5.7, 7.4, 8.6, 9.7, 16.1, 9.2, 8.6, 14.3, 9.7, 6.9, 13.8, 11.5, 10.9, 9.2, 8.0, 13.8, 11.5, 14.9, 20.7, 9.2, 11.5, 10.3, 6.3, 1.7, 4.6, 6.3, 8.0, 8.0, 10.3, 11.5, 14.9, 8.0, 4.1, 9.2, 9.2, 10.9, 4.6, 10.9, 5.1, 6.3, 5.7, 7.4, 8.6, 14.3, 14.9, 14.9, 14.3, 6.9, 10.3, 6.3, 5.1, 11.5, 6.9, 9.7, 11.5, 8.6, 8.0, 8.6, 12.0, 7.4, 7.4, 7.4, 9.2, 6.9, 13.8, 7.4, 6.9, 7.4, 4.6, 4.0, 10.3, 8.0, 8.6, 11.5, 11.5, 11.5, 9.7, 11.5, 10.3, 6.3, 7.4, 10.9, 10.3, 15.5, 14.3, 12.6, 9.7, 3.4, 8.0, 5.7, 9.7, 2.3, 6.3, 6.3, 6.9, 5.1, 2.8, 4.6, 7.4, 15.5, 10.9, 10.3, 10.9, 9.7, 14.9, 15.5, 6.3, 10.9, 11.5, 6.9, 13.8, 10.3, 10.3, 8.0, 12.6, 9.2, 10.3, 10.3, 16.6, 6.9, 13.2, 14.3, 8.0, 11.5]
  },
  "cases": [
    {
      "name": "standard_theta10_kappa2_moments",
      "construct": { "params": [10.0, 2.0] },
      "assertions": [
        { "method": "mean",             "args": [], "expected": 20.0,               "mode": "abs", "tol": 1e-12 },
        { "method": "mode",             "args": [], "expected": 10.0,               "mode": "abs", "tol": 1e-12 },
        { "method": "sd",               "args": [], "expected": 14.142135623730951,  "mode": "abs", "tol": 1e-4 },
        { "method": "skewness",         "args": [], "expected": 1.4142135623730951,  "mode": "abs", "tol": 1e-4 },
        { "method": "kurtosis",         "args": [], "expected": 6.0,                "mode": "abs", "tol": 1e-12 },
        { "method": "parameters_valid", "args": [], "expected": true,               "mode": "bool" }
      ]
    },
    {
      "name": "pdf_theta10_kappa1",
      "construct": { "params": [10.0, 1.0] },
      "assertions": [
        { "method": "pdf", "args": [1.0],  "expected": 0.090483741803595957, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [10.0], "expected": 0.036787944117144233, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "pdf_theta1_kappa1",
      "construct": { "params": [1.0, 1.0] },
      "assertions": [
        { "method": "pdf", "args": [1.0],  "expected": 0.36787944117144233,  "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [10.0], "expected": 0.000045399929762484854, "mode": "abs", "tol": 1e-10 }
      ]
    },
    {
      "name": "cdf_theta10_kappa1",
      "construct": { "params": [10.0, 1.0] },
      "assertions": [
        { "method": "cdf", "args": [1.0],  "expected": 0.09516258196404043, "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [10.0], "expected": 0.6321205588285578,  "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "cdf_theta1_kappa1",
      "construct": { "params": [1.0, 1.0] },
      "assertions": [
        { "method": "cdf", "args": [10.0], "expected": 0.9999546000702375, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "cdf_theta0p1_kappa10_large_x",
      "construct": { "params": [0.1, 10.0] },
      "assertions": [
        { "method": "cdf", "args": [1.0],  "expected": 0.54207028552814611, "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [10.0], "expected": 0.99999974397923107, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "quantile_theta10_kappa1",
      "construct": { "params": [10.0, 1.0] },
      "assertions": [
        { "method": "quantile", "args": [0.0],                 "expected": 0.0,  "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.09516258196404043], "expected": 1.0,  "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.6321205588285578],  "expected": 10.0, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "quantile_mle_params",
      "construct": { "params": [11.322893655, 16.89937] },
      "assertions": [
        { "method": "quantile", "args": [0.99], "expected": 315.87, "mode": "rel", "tol": 0.01 }
      ]
    },
    {
      "name": "invalid_params",
      "construct": { "params": [-1.0, 0.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "kurtosis_kappa6",
      "construct": { "params": [10.0, 6.0] },
      "assertions": [
        { "method": "kurtosis", "args": [], "expected": 4.0, "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "lmom_fit_wind_data",
      "construct": { "fit": { "method": "lmom", "dataset": "wind" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 1.280143, "mode": "abs", "tol": 0.0001 },
        { "method": "param", "args": [1], "expected": 7.778442, "mode": "abs", "tol": 0.0001 }
      ]
    },
    {
      "name": "lmom_from_params_wind_data",
      "construct": { "params": [1.280143, 7.778442] },
      "assertions": [
        { "method": "linear_moment", "args": [0], "expected": 9.9575163, "mode": "abs", "tol": 0.0001 },
        { "method": "linear_moment", "args": [1], "expected": 1.9822363, "mode": "abs", "tol": 0.0001 },
        { "method": "linear_moment", "args": [2], "expected": 0.1175059, "mode": "abs", "tol": 0.0001 },
        { "method": "linear_moment", "args": [3], "expected": 0.1268391, "mode": "abs", "tol": 0.0001 }
      ]
    },
    {
      "name": "seeded_random_draws",
      "source": "curated via oracle_emitter --dump (GenerateRandomValues(sampleSize, seed))",
      "construct": { "params": [10.0, 2.0] },
      "assertions": [
        { "method": "random_value", "args": [50, 123, 0], "expected": 24.22702630960793, "mode": "rel", "tol": 1e-11 },
        { "method": "random_value", "args": [50, 123, 1], "expected": 25.012324302925894, "mode": "rel", "tol": 1e-11 },
        { "method": "random_value", "args": [50, 123, 2], "expected": 10.59559719594355, "mode": "rel", "tol": 1e-11 },
        { "method": "random_value", "args": [50, 123, 49], "expected": 14.262927458637133, "mode": "rel", "tol": 1e-11 }
      ]
    },
    {
      "name": "partial_kp_zero_skew_limit_and_continuity",
      "comment": "Mirrors Test_PartialKp_ZeroSkewLimitAndContinuity (v2.1.4): PartialKp is documented as a DERIVATIVE, so its near-zero-skew branch must return the Cornish-Fisher derivative limit (z*z-1)/6, not the frequency factor itself (the pre-2.1.4 value, StandardZ(p)). construct.params is an arbitrary valid GammaDistribution instance -- partial_kp is a static utility independent of it.",
      "construct": { "params": [10.0, 2.0] },
      "assertions": [
        { "method": "partial_kp", "args": [0.0, 0.9],      "expected": 0.10706240252496946, "mode": "abs", "tol": 1e-15 },
        { "method": "partial_kp", "args": [9.9e-5, 0.9],   "expected": 0.10706240252496946, "mode": "abs", "tol": 1e-15 },
        { "method": "partial_kp", "args": [-9.9e-5, 0.9],  "expected": 0.10706240252496946, "mode": "abs", "tol": 1e-15 },
        { "method": "partial_kp", "args": [1.01e-4, 0.9],  "expected": 0.10705277093275629, "mode": "abs", "tol": 1e-4 },
        { "method": "partial_kp", "args": [-1.01e-4, 0.9], "expected": 0.10707203408328507, "mode": "abs", "tol": 1e-4 }
      ]
    }
  ]
}
