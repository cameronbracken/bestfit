{
  "target": "Normal",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_Normal.cs",
  "reference": "Rao & Hamed, Flood Frequency Analysis, CRC Press 2000; math.net DistributionTests",
  "datasets": {
    "tippecanoe": [6290, 2700, 13100, 16900, 14600, 9600, 7740, 8490, 8130, 12000, 17200, 15000, 12400, 6960, 6500, 5840, 10400, 18800, 21400, 22600, 14200, 11000, 12800, 15700, 4740, 6950, 11800, 12100, 20600, 14600, 14600, 8900, 10600, 14200, 14100, 14100, 12500, 7530, 13400, 17600, 13400, 19200, 16900, 15500, 14500, 21900, 10400, 7460],
    "wind": [7.4, 8, 12.6, 11.5, 14.3, 14.9, 8.6, 13.8, 20.1, 8.6, 6.9, 9.7, 9.2, 10.9, 13.2, 11.5, 12, 18.4, 11.5, 9.7, 9.7, 16.6, 9.7, 12, 16.6, 14.9, 8, 12, 14.9, 5.7, 7.4, 8.6, 9.7, 16.1, 9.2, 8.6, 14.3, 9.7, 6.9, 13.8, 11.5, 10.9, 9.2, 8, 13.8, 11.5, 14.9, 20.7, 9.2, 11.5, 10.3, 6.3, 1.7, 4.6, 6.3, 8, 8, 10.3, 11.5, 14.9, 8, 4.1, 9.2, 9.2, 10.9, 4.6, 10.9, 5.1, 6.3, 5.7, 7.4, 8.6, 14.3, 14.9, 14.9, 14.3, 6.9, 10.3, 6.3, 5.1, 11.5, 6.9, 9.7, 11.5, 8.6, 8, 8.6, 12, 7.4, 7.4, 7.4, 9.2, 6.9, 13.8, 7.4, 6.9, 7.4, 4.6, 4, 10.3, 8, 8.6, 11.5, 11.5, 11.5, 9.7, 11.5, 10.3, 6.3, 7.4, 10.9, 10.3, 15.5, 14.3, 12.6, 9.7, 3.4, 8, 5.7, 9.7, 2.3, 6.3, 6.3, 6.9, 5.1, 2.8, 4.6, 7.4, 15.5, 10.9, 10.3, 10.9, 9.7, 14.9, 15.5, 6.3, 10.9, 11.5, 6.9, 13.8, 10.3, 10.3, 8, 12.6, 9.2, 10.3, 10.3, 16.6, 6.9, 13.2, 14.3, 8, 11.5]
  },
  "cases": [
    {
      "name": "standard_pdf_moments",
      "construct": { "params": [0, 1] },
      "assertions": [
        { "method": "pdf",      "args": [0], "expected": 0.39894, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf",      "args": [1], "expected": 0.24197, "mode": "abs", "tol": 1e-4 },
        { "method": "mean",     "args": [], "expected": 0, "mode": "equal" },
        { "method": "median",   "args": [], "expected": 0, "mode": "equal" },
        { "method": "mode",     "args": [], "expected": 0, "mode": "equal" },
        { "method": "sd",       "args": [], "expected": 1, "mode": "equal" },
        { "method": "skewness", "args": [], "expected": 0, "mode": "equal" },
        { "method": "kurtosis", "args": [], "expected": 3, "mode": "equal" },
        { "method": "minimum",  "args": [], "expected": "-inf", "mode": "equal" },
        { "method": "maximum",  "args": [], "expected": "inf", "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "mu5_sigma9",
      "construct": { "params": [5, 9] },
      "assertions": [
        { "method": "pdf",      "args": [-1], "expected": 0.03549, "mode": "abs", "tol": 1e-4 },
        { "method": "mean",     "args": [], "expected": 5, "mode": "equal" },
        { "method": "median",   "args": [], "expected": 5, "mode": "equal" },
        { "method": "mode",     "args": [], "expected": 5, "mode": "equal" },
        { "method": "sd",       "args": [], "expected": 9, "mode": "equal" },
        { "method": "skewness", "args": [], "expected": 0, "mode": "equal" },
        { "method": "kurtosis", "args": [], "expected": 3, "mode": "equal" }
      ]
    },
    {
      "name": "cdf_mu5_sigma2",
      "construct": { "params": [5, 2] },
      "assertions": [
        { "method": "cdf", "args": [0], "expected": 0.006209, "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [4], "expected": 0.30853,  "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [5], "expected": 0.5,      "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "quantile",
      "construct": { "params": [12665, 4710] },
      "assertions": [
        { "method": "quantile", "args": [0.99], "expected": 23624, "mode": "rel", "tol": 0.01 }
      ]
    },
    {
      "name": "invalid_nan_location",
      "construct": { "params": ["nan", 1] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "invalid_nan_scale",
      "construct": { "params": [1, "nan"] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "invalid_inf_location",
      "construct": { "params": ["inf", 1] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "invalid_inf_scale",
      "construct": { "params": [1, "inf"] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "mom_fit",
      "construct": { "fit": { "dataset": "tippecanoe", "method": "mom" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 12665, "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": [1], "expected": 4710,  "mode": "rel", "tol": 0.01 }
      ]
    },
    {
      "name": "mle_fit",
      "construct": { "fit": { "dataset": "tippecanoe", "method": "mle" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 12665, "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": [1], "expected": 4660,  "mode": "rel", "tol": 0.01 }
      ]
    },
    {
      "name": "lmom_fit",
      "construct": { "fit": { "dataset": "wind", "method": "lmom" } },
      "assertions": [
        { "method": "param",         "args": [0], "expected": 9.957516, "mode": "abs", "tol": 1e-4 },
        { "method": "param",         "args": [1], "expected": 3.513431, "mode": "abs", "tol": 1e-4 },
        { "method": "linear_moment", "args": [0], "expected": 9.9575163, "mode": "abs", "tol": 1e-4 },
        { "method": "linear_moment", "args": [1], "expected": 1.9822411, "mode": "abs", "tol": 1e-4 },
        { "method": "linear_moment", "args": [2], "expected": 0.0,       "mode": "abs", "tol": 1e-4 },
        { "method": "linear_moment", "args": [3], "expected": 0.1226017, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "seeded_random_draws",
      "source": "curated via oracle_emitter --dump (GenerateRandomValues(sampleSize, seed))",
      "construct": { "params": [100.0, 15.0] },
      "assertions": [
        { "method": "random_value", "args": [50, 123, 0], "expected": 107.71408449723363, "mode": "rel", "tol": 1e-11 },
        { "method": "random_value", "args": [50, 123, 1], "expected": 108.43058699238804, "mode": "rel", "tol": 1e-11 },
        { "method": "random_value", "args": [50, 123, 2], "expected": 91.5295185930817, "mode": "rel", "tol": 1e-11 },
        { "method": "random_value", "args": [50, 123, 49], "expected": 96.86445536173657, "mode": "rel", "tol": 1e-11 },
        { "method": "random_value", "args": [100, 42, 0], "expected": 95.20221411105254, "mode": "rel", "tol": 1e-11 },
        { "method": "random_value", "args": [100, 42, 99], "expected": 72.0724996909374, "mode": "rel", "tol": 1e-11 }
      ]
    }
  ]
}
