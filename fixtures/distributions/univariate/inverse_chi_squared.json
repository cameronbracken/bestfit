{
  "target": "InverseChiSquared",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_InverseChiSquared.cs",
  "cases": [
    {
      "name": "default_moments",
      "construct": { "params": [10.0, 1.0] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 1.25,              "mode": "abs", "tol": 1e-12 },
        { "method": "median",   "args": [], "expected": 1.07046,           "mode": "abs", "tol": 1e-4  },
        { "method": "mode",     "args": [], "expected": 0.8333,            "mode": "abs", "tol": 1e-4  },
        { "method": "sd",       "args": [], "expected": 0.72168,           "mode": "abs", "tol": 1e-4  },
        { "method": "skewness", "args": [], "expected": 3.46410,           "mode": "abs", "tol": 1e-4  },
        { "method": "kurtosis", "args": [], "expected": 45.0,              "mode": "abs", "tol": 1e-12 },
        { "method": "parameters_valid", "args": [], "expected": true,      "mode": "bool"              }
      ]
    },
    {
      "name": "dof2_mean_nan",
      "construct": { "params": [2.0, 2.0] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": "nan", "mode": "equal" },
        { "method": "sd",       "args": [], "expected": "nan", "mode": "equal" },
        { "method": "skewness", "args": [], "expected": "nan", "mode": "equal" },
        { "method": "kurtosis", "args": [], "expected": "nan", "mode": "equal" },
        { "method": "mode",     "args": [], "expected": 1.0,   "mode": "abs", "tol": 1e-12 }
      ]
    },
    {
      "name": "dof7_sigma1_median",
      "construct": { "params": [7.0, 1.0] },
      "assertions": [
        { "method": "median",   "args": [], "expected": 1.10309, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "dof1_sigma1_pdf",
      "construct": { "params": [1.0, 1.0] },
      "assertions": [
        { "method": "pdf", "args": [1.0], "expected": 0.2419, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "dof2_sigma1_pdf",
      "construct": { "params": [2.0, 1.0] },
      "assertions": [
        { "method": "pdf", "args": [2.0], "expected": 0.15163, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "dof10_sigma1_pdf",
      "construct": { "params": [10.0, 1.0] },
      "assertions": [
        { "method": "pdf", "args": [2.0], "expected": 0.16700, "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "dof7_sigma1_cdf",
      "construct": { "params": [7.0, 1.0] },
      "assertions": [
        { "method": "cdf", "args": [5.0], "expected": 0.985571264449, "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "dof10_sigma1_quantile",
      "construct": { "params": [10.0, 1.0] },
      "assertions": [
        { "method": "quantile", "args": [0.0],  "expected": 0.0,               "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.3],  "expected": 0.84884,           "mode": "abs", "tol": 1e-4  },
        { "method": "quantile", "args": [0.1],  "expected": 0.6255012152,      "mode": "abs", "tol": 1e-4  },
        { "method": "quantile", "args": [0.5],  "expected": 1.0704554778,      "mode": "abs", "tol": 1e-4  },
        { "method": "quantile", "args": [0.7],  "expected": 1.3760423551,      "mode": "abs", "tol": 1e-4  },
        { "method": "quantile", "args": [0.9],  "expected": 2.0554215430,      "mode": "abs", "tol": 1e-4  }
      ]
    },
    {
      "name": "dof7_sigma1over7_main_test",
      "construct": { "params": [7.0, 0.14285714285714285] },
      "assertions": [
        { "method": "mean",     "args": [],     "expected": 0.2,                     "mode": "abs", "tol": 1e-4  },
        { "method": "median",   "args": [],     "expected": 0.15758426609,           "mode": "abs", "tol": 1e-4  },
        { "method": "pdf",      "args": [6.27], "expected": 0.0000063457380298844403, "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [6.27], "expected": 0.9999884277,            "mode": "abs", "tol": 1e-6  },
        { "method": "quantile", "args": [0.9999884277], "expected": 6.27,           "mode": "abs", "tol": 1e-3  }
      ]
    },
    {
      "name": "dof10_sigma1_cdf_roundtrip",
      "construct": { "params": [10.0, 1.0] },
      "assertions": [
        { "method": "cdf",      "args": [0.5], "expected": 0.0292526881, "mode": "abs", "tol": 1e-6 },
        { "method": "cdf",      "args": [1.0], "expected": 0.4404932851, "mode": "abs", "tol": 1e-6 },
        { "method": "cdf",      "args": [2.0], "expected": 0.8911780189, "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "dof5_sigma2_cdf",
      "construct": { "params": [5.0, 2.0] },
      "assertions": [
        { "method": "cdf", "args": [0.5], "expected": 0.0012497306, "mode": "abs", "tol": 1e-6 },
        { "method": "cdf", "args": [2.0], "expected": 0.4158801870, "mode": "abs", "tol": 1e-6 },
        { "method": "cdf", "args": [5.0], "expected": 0.8491450361, "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "invalid_params",
      "construct": { "params": [0.0, 0.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "minimum_maximum",
      "construct": { "params": [10.0, 1.0] },
      "assertions": [
        { "method": "minimum", "args": [], "expected": 0.0, "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.0], "expected": 0.0, "mode": "abs", "tol": 1e-12 }
      ]
    }
  ]
}
