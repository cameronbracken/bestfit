{
  "target": "Logistic",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_Logistic.cs",
  "reference": "Rao & Hamed, Flood Frequency Analysis, CRC Press 2000",
  "datasets": {
    "tippecanoe": [6290, 2700, 13100, 16900, 14600, 9600, 7740, 8490, 8130, 12000, 17200, 15000, 12400, 6960, 6500, 5840, 10400, 18800, 21400, 22600, 14200, 11000, 12800, 15700, 4740, 6950, 11800, 12100, 20600, 14600, 14600, 8900, 10600, 14200, 14100, 14100, 12500, 7530, 13400, 17600, 13400, 19200, 16900, 15500, 14500, 21900, 10400, 7460]
  },
  "cases": [
    {
      "name": "standard_pdf_cdf_moments",
      "construct": { "params": [0.0, 1.0] },
      "assertions": [
        { "method": "pdf",      "args": [0.0], "expected": 0.25, "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [0.0], "expected": 0.5, "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.5], "expected": 0.0, "mode": "abs", "tol": 1e-12 },
        { "method": "mean",     "args": [], "expected": 0.0, "mode": "equal" },
        { "method": "median",   "args": [], "expected": 0.0, "mode": "equal" },
        { "method": "mode",     "args": [], "expected": 0.0, "mode": "equal" },
        { "method": "sd",       "args": [], "expected": 1.8137993642342178, "mode": "abs", "tol": 1e-12 },
        { "method": "skewness", "args": [], "expected": 0.0, "mode": "equal" },
        { "method": "kurtosis", "args": [], "expected": 4.2, "mode": "abs", "tol": 1e-12 },
        { "method": "minimum",  "args": [], "expected": "-inf", "mode": "equal" },
        { "method": "maximum",  "args": [], "expected": "inf", "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "logistic_5_2",
      "construct": { "params": [5.0, 2.0] },
      "assertions": [
        { "method": "pdf",      "args": [-5.0], "expected": 0.0033240283353950773, "mode": "abs", "tol": 1e-10 },
        { "method": "pdf",      "args": [0.0],  "expected": 0.03505185827255408,   "mode": "abs", "tol": 1e-10 },
        { "method": "pdf",      "args": [5.0],  "expected": 0.125,                 "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [-5.0], "expected": 0.0066928509242848554, "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [0.0],  "expected": 0.07585818002124355,   "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [5.0],  "expected": 0.5,                   "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.3],  "expected": 3.305404279225593,     "mode": "abs", "tol": 1e-9 },
        { "method": "quantile", "args": [0.0],  "expected": "-inf",                "mode": "equal" },
        { "method": "quantile", "args": [1.0],  "expected": "inf",                 "mode": "equal" }
      ]
    },
    {
      "name": "invalid_nan_location",
      "construct": { "params": ["nan", 1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "invalid_inf_location",
      "construct": { "params": ["inf", 1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "mom_fit",
      "construct": { "fit": { "dataset": "tippecanoe", "method": "mom" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 12665.0, "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": [1], "expected": 2596.62, "mode": "rel", "tol": 0.01 }
      ]
    },
    {
      "name": "mle_fit",
      "construct": { "fit": { "dataset": "tippecanoe", "method": "mle" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 12628.59, "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": [1], "expected": 2708.64, "mode": "rel", "tol": 0.01 }
      ]
    }
  ]
}
