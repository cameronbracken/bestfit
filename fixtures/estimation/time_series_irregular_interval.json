      11.7, 12.5, 13.9, 15.2, 14.1, 12.9, 13.6, 15.0, 16.2, 14.8,
      13.3, 14.7, 16.0, 15.1, 13.8, 14.4, 15.9, 17.1, 16.3, 15.0,
      14.2, 15.6, 16.8, 15.9, 14.6, 15.3, 16.7, 18.0, 17.2, 15.8
    ]
  },
