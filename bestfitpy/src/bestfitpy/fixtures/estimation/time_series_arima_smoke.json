{
  "target": "MaximumLikelihood",
  "kind": "model_estimation",
  "source": "Emitter oracle (Task P4): fitted parameters, log-likelihood, AIC and the seeded ISimulatable draw dumped from the REAL RMC.BestFit ARIMA(1,1,1) MLE (Numerics @ a2c4dbf, RMC-BestFit @ fc28c0c) via tools/oracle_emitter and reproduced by tools/verify_oracles.py. Optimizer-dependent fit quantities carry rel 1e-8 (the C++/R/Python port reproduces the C# values to ~1e-13). The near-zero differenced intercept (param 0) is deliberately NOT asserted -- a relative tolerance against ~0 is meaningless.",
  "datasets": {
    "series": [10.2, 11.5, 9.8, 12.1, 13.4, 11.9, 10.6, 12.8, 14.0, 13.1, 11.7, 12.5, 13.9, 15.2, 14.1, 12.9, 13.6, 15.0, 16.2, 14.8]
  },
  "cases": [
    {
      "name": "arima_1_1_1_nelder_mead",
      "construct": {
        "model": {
          "type": "time_series",
          "subtype": "arima",
          "dataset": "series",
          "orders": { "p": 1, "d": 1, "q": 1 },
          "include_intercept": true,
          "transform": "None"
        },
        "optimizer": "NelderMead",
        "sample_size": 6,
        "seed": 42
      },
      "assertions": [
        { "method": "parameter", "args": [1], "expected": -0.9368602116073409, "mode": "rel", "tol": 1e-8 },
        { "method": "parameter", "args": [2], "expected": 1.791054290479591, "mode": "rel", "tol": 1e-8 },
        { "method": "parameter", "args": [3], "expected": 0.9705556665088798, "mode": "rel", "tol": 1e-8 },
        { "method": "max_log_likelihood", "args": [], "expected": -23.486691308733704, "mode": "rel", "tol": 1e-8 },
        { "method": "aic", "args": [], "expected": 54.97338261746741, "mode": "rel", "tol": 1e-8 },
        { "method": "simulated_value", "args": [1], "expected": 0.54975802115366, "mode": "rel", "tol": 1e-8 },
        { "method": "simulated_value", "args": [2], "expected": 2.549178831762233, "mode": "rel", "tol": 1e-8 }
      ]
    }
  ]
