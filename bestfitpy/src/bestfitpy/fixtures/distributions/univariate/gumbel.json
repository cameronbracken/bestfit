{
  "target": "Gumbel",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_Gumbel.cs",
  "reference": "Rao & Hamed, Flood Frequency Analysis, CRC Press 2000",
  "datasets": {
    "sugar_creek": [17600, 3660, 903, 5050, 24000, 11400, 9470, 8970, 7710, 14800, 13900, 20800, 9470, 7860, 7860, 2730, 6480, 18200, 26300, 15100, 14600, 7300, 8580, 15100, 15100, 21800, 6200, 2130, 11100, 14300, 11200, 6670, 5440, 9370, 6900, 9680, 6810, 7730, 5290, 12200, 9750, 7390, 13100, 7190, 8850, 6290, 18800, 9740, 2990, 6950, 9390, 12400, 21200],
    "lmom_sample": [1953, 1939, 1677, 1692, 2051, 2371, 2022, 1521, 1448, 1825, 1363, 1760, 1672, 1603, 1244, 1521, 1783, 1560, 1357, 1673, 1625, 1425, 1688, 1577, 1736, 1640, 1584, 1293, 1277, 1742, 1491]
  },
  "cases": [
    {
      "name": "standard_pdf_cdf_moments",
      "construct": { "params": [0.0, 1.0] },
      "assertions": [
        { "method": "pdf",      "args": [0.0], "expected": 0.36787944117144233, "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [0.0], "expected": 0.36787944117144233, "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.36787944117144233], "expected": 0.0, "mode": "abs", "tol": 1e-9 },
        { "method": "mean",     "args": [], "expected": 0.5772156649015329, "mode": "abs", "tol": 1e-12 },
        { "method": "median",   "args": [], "expected": 0.36651292058166435, "mode": "abs", "tol": 1e-12 },
        { "method": "mode",     "args": [], "expected": 0.0, "mode": "equal" },
        { "method": "sd",       "args": [], "expected": 1.2825498301618641, "mode": "abs", "tol": 1e-12 },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "default_100_10",
      "construct": { "params": [100.0, 10.0] },
      "assertions": [
        { "method": "pdf",      "args": [100.0], "expected": 0.0367879441171442, "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [100.0], "expected": 0.36787944117144233, "mode": "abs", "tol": 1e-10 },
        { "method": "mean",     "args": [], "expected": 105.77215664901533, "mode": "abs", "tol": 1e-4 },
        { "method": "median",   "args": [], "expected": 103.6651292058166, "mode": "abs", "tol": 1e-5 },
        { "method": "sd",       "args": [], "expected": 12.82549830161864, "mode": "abs", "tol": 1e-4 },
        { "method": "skewness", "args": [], "expected": 1.1396, "mode": "equal" },
        { "method": "kurtosis", "args": [], "expected": 5.4, "mode": "equal" },
        { "method": "minimum",  "args": [], "expected": "-inf", "mode": "equal" },
        { "method": "maximum",  "args": [], "expected": "inf", "mode": "equal" },
        { "method": "quantile", "args": [0.3],  "expected": 98.14373, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.7],  "expected": 110.309304, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.0],  "expected": "-inf", "mode": "equal" },
        { "method": "quantile", "args": [1.0],  "expected": "inf", "mode": "equal" }
      ]
    },
    {
      "name": "invalid_nan_location",
      "construct": { "params": ["nan", 1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "invalid_inf_location",
      "construct": { "params": ["inf", 1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "mom_fit",
      "construct": { "fit": { "dataset": "sugar_creek", "method": "mom" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 8074.4, "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": [1], "expected": 4441.4, "mode": "rel", "tol": 0.01 }
      ]
    },
    {
      "name": "mle_fit",
      "construct": { "fit": { "dataset": "sugar_creek", "method": "mle" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 8049.6, "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": [1], "expected": 4478.6, "mode": "rel", "tol": 0.01 }
      ]
    },
    {
      "name": "lmom_fit",
      "construct": { "fit": { "dataset": "lmom_sample", "method": "lmom" } },
      "assertions": [
        { "method": "param",         "args": [0], "expected": 1533.69,   "mode": "abs", "tol": 0.001 },
        { "method": "param",         "args": [1], "expected": 199.4332,  "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [0], "expected": 1648.806,  "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [1], "expected": 138.2366,  "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [2], "expected": 0.169925,  "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [3], "expected": 0.150375,  "mode": "abs", "tol": 0.001 }
      ]
    }
  ]
}
