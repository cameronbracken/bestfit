{
  "target": "Exponential",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_Exponential.cs",
  "reference": "Rao & Hamed, Flood Frequency Analysis, CRC Press 2000; R 'lmom'",
  "datasets": {
    "wabash": [41500, 57000, 44000, 49000, 31000, 45900, 19000, 41100, 37300, 76000, 33200, 61200, 76000, 59800, 44400, 58400, 53600, 59800, 63300, 57700, 64000, 63500, 38000, 74600, 13100, 37600, 67500, 21700, 37000, 93500, 58500, 63300, 74400, 34200, 14600, 44200, 13100, 73300, 46600, 39400, 41200, 41300, 62000, 90000, 50600, 41900, 35000, 16500, 35300, 30000, 52600, 99000, 89000, 39500, 55400, 46000, 63000, 58300, 36500, 14600, 64900, 68500, 69100, 42600, 31000, 39400, 40700, 53400, 36000, 43900, 23600, 50500, 49700, 48100, 44500, 56400, 60800, 40400, 80400, 41600, 14700, 33300, 40700, 53300, 77400],
    "lmom_sample": [1953, 1939, 1677, 1692, 2051, 2371, 2022, 1521, 1448, 1825, 1363, 1760, 1672, 1603, 1244, 1521, 1783, 1560, 1357, 1673, 1625, 1425, 1688, 1577, 1736, 1640, 1584, 1293, 1277, 1742, 1491]
  },
  "cases": [
    {
      "name": "pdf_cdf_loc0_scale3",
      "construct": { "params": [0, 3] },
      "assertions": [
        { "method": "pdf", "args": [0], "expected": 0.33333,    "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [1], "expected": 0.23884377, "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [2], "expected": 0.171139,   "mode": "abs", "tol": 1e-4 },
        { "method": "pdf", "args": [3], "expected": 0.122626,   "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [0], "expected": 0,          "mode": "equal" },
        { "method": "cdf", "args": [1], "expected": 0.2834686, "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [2], "expected": 0.4865828, "mode": "abs", "tol": 1e-4 },
        { "method": "cdf", "args": [3], "expected": 0.632120,  "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "loc0_scale1",
      "construct": { "params": [0, 1] },
      "assertions": [
        { "method": "quantile", "args": [0],   "expected": 0,        "mode": "equal" },
        { "method": "quantile", "args": [1],   "expected": "inf",    "mode": "equal" },
        { "method": "quantile", "args": [0.5], "expected": 0.693147, "mode": "abs", "tol": 1e-4 },
        { "method": "median",   "args": [], "expected": 0.693147, "mode": "abs", "tol": 1e-4 },
        { "method": "mode",     "args": [], "expected": 0, "mode": "equal" },
        { "method": "sd",       "args": [], "expected": 1, "mode": "equal" },
        { "method": "skewness", "args": [], "expected": 2, "mode": "equal" },
        { "method": "kurtosis", "args": [], "expected": 9, "mode": "equal" },
        { "method": "minimum",  "args": [], "expected": 0, "mode": "equal" },
        { "method": "maximum",  "args": [], "expected": "inf", "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
    {
      "name": "default_100_10_quantiles",
      "construct": { "params": [100, 10] },
      "assertions": [
        { "method": "quantile", "args": [0.3], "expected": 103.5667494, "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.5], "expected": 106.93147,   "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.7], "expected": 112.039728,  "mode": "abs", "tol": 1e-4 }
      ]
    },
    {
      "name": "mean_1_1",
      "construct": { "params": [1, 1] },
      "assertions": [ { "method": "mean", "args": [], "expected": 2, "mode": "equal" } ]
    },
    {
      "name": "mean_neg100_4",
      "construct": { "params": [-100, 4] },
      "assertions": [ { "method": "mean", "args": [], "expected": -96, "mode": "equal" } ]
    },
    {
      "name": "neg100_1",
      "construct": { "params": [-100, 1] },
      "assertions": [
        { "method": "median",  "args": [], "expected": -99.306852, "mode": "abs", "tol": 1e-4 },
        { "method": "mode",    "args": [], "expected": -100, "mode": "equal" },
        { "method": "sd",      "args": [], "expected": 1, "mode": "equal" },
        { "method": "minimum", "args": [], "expected": -100, "mode": "equal" }
      ]
    },
    {
      "name": "invalid_nan_location",
      "construct": { "params": ["nan", 5] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "invalid_inf_location",
      "construct": { "params": ["inf", 100] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "invalid_neg_inf_scale",
      "construct": { "params": [0, "-inf"] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "invalid_nan_scale",
      "construct": { "params": [1, "nan"] },
      "assertions": [ { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" } ]
    },
    {
      "name": "mom_fit",
      "construct": { "fit": { "dataset": "wabash", "method": "mom" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 30314.48, "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": [1], "expected": 18907.87, "mode": "rel", "tol": 0.01 }
      ]
    },
    {
      "name": "mle_fit",
      "construct": { "fit": { "dataset": "wabash", "method": "mle" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 13100,    "mode": "rel", "tol": 0.01 },
        { "method": "param", "args": [1], "expected": 36122.35, "mode": "rel", "tol": 0.01 }
      ]
    },
    {
      "name": "lmom_fit",
      "construct": { "fit": { "dataset": "lmom_sample", "method": "lmom" } },
      "assertions": [
        { "method": "param",         "args": [0], "expected": 1372.333,  "mode": "abs", "tol": 0.001 },
        { "method": "param",         "args": [1], "expected": 276.4731,  "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [0], "expected": 1648.806,  "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [1], "expected": 138.2366,  "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [2], "expected": 0.3333333, "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [3], "expected": 0.1666667, "mode": "abs", "tol": 0.001 }
      ]
    }
  ]
}
