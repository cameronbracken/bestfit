{
  "target": "GeneralizedLogistic",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_GeneralizedLogistic.cs",
  "reference": "Rao & Hamed, Flood Frequency Analysis, CRC Press 2000",
  "datasets": {
    "east_fork_white": [24000, 7920, 21900, 47100, 30400, 36100, 67100, 7030, 28200, 40100, 10300, 11100, 17000, 65600, 32600, 36200, 46400, 3650, 16800, 44800, 37100, 42900, 15000, 33000, 28000, 78500, 54000, 28600, 44000, 13300, 6120, 11100, 42100, 33400, 30100, 32100, 28100, 59400, 23800, 52000, 54900, 25600, 10900, 33700, 60200, 39200, 26300, 27900, 27000, 22700, 17500, 46400, 19300, 12700, 36000, 39900, 25400, 30200, 47000, 39800, 23800, 29600, 33400, 15400, 28400, 26700, 46500, 61200],
    "lmom_sample": [1953, 1939, 1677, 1692, 2051, 2371, 2022, 1521, 1448, 1825, 1363, 1760, 1672, 1603, 1244, 1521, 1783, 1560, 1357, 1673, 1625, 1425, 1688, 1577, 1736, 1640, 1584, 1293, 1277, 1742, 1491]
  },
  "cases": [
    {
      "name": "kappa_zero_limit_branch",
      "comment": "kappa=0 exercises the near-zero limit: reduces to logistic distribution",
      "construct": { "params": [0.0, 1.0, 0.0] },
      "assertions": [
        { "method": "pdf",      "args": [0.0],  "expected": 0.25,                  "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [0.0],  "expected": 0.5,                   "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.0],  "expected": "-inf",                "mode": "equal" },
        { "method": "quantile", "args": [0.5],  "expected": 0.0,                   "mode": "abs",  "tol": 1e-9 },
        { "method": "quantile", "args": [1.0],  "expected": "inf",                 "mode": "equal" },
        { "method": "mean",     "args": [],     "expected": 0.0,                   "mode": "equal" },
        { "method": "median",   "args": [],     "expected": 0.0,                   "mode": "abs",  "tol": 1e-9 },
        { "method": "mode",     "args": [],     "expected": 0.0,                   "mode": "equal" },
        { "method": "sd",       "args": [],     "expected": 1.8137993642342178,    "mode": "abs",  "tol": 1e-9 },
        { "method": "skewness", "args": [],     "expected": 0.0,                   "mode": "equal" },
        { "method": "kurtosis", "args": [],     "expected": 4.2,                   "mode": "abs",  "tol": 1e-12 },
        { "method": "minimum",  "args": [],     "expected": "-inf",                "mode": "equal" },
        { "method": "maximum",  "args": [],     "expected": "inf",                 "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true,              "mode": "bool" }
      ]
    },
    {
      "name": "default_100_10_0",
      "comment": "default constructor: xi=100, alpha=10, kappa=0",
      "construct": { "params": [100.0, 10.0, 0.0] },
      "assertions": [
        { "method": "pdf",      "args": [100.0], "expected": 0.025,               "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [100.0], "expected": 0.5,                 "mode": "abs", "tol": 1e-12 },
        { "method": "mean",     "args": [],      "expected": 100.0,               "mode": "equal" },
        { "method": "median",   "args": [],      "expected": 100.0,               "mode": "abs",  "tol": 1e-9 },
        { "method": "mode",     "args": [],      "expected": 100.0,               "mode": "equal" },
        { "method": "sd",       "args": [],      "expected": 18.137993642342178,  "mode": "abs",  "tol": 1e-6 },
        { "method": "skewness", "args": [],      "expected": 0.0,                 "mode": "equal" },
        { "method": "kurtosis", "args": [],      "expected": 4.2,                 "mode": "abs",  "tol": 1e-12 },
        { "method": "minimum",  "args": [],      "expected": "-inf",              "mode": "equal" },
        { "method": "maximum",  "args": [],      "expected": "inf",               "mode": "equal" }
      ]
    },
    {
      "name": "positive_kappa_bounded_above",
      "comment": "xi=100, alpha=10, kappa=1: bounded above at xi+alpha/kappa=110",
      "construct": { "params": [100.0, 10.0, 1.0] },
      "assertions": [
        { "method": "mean",     "args": [],      "expected": "nan",  "mode": "equal" },
        { "method": "sd",       "args": [],      "expected": "nan",  "mode": "equal" },
        { "method": "skewness", "args": [],      "expected": "nan",  "mode": "equal" },
        { "method": "mode",     "args": [],      "expected": 95.0,   "mode": "abs",  "tol": 1e-9 },
        { "method": "minimum",  "args": [],      "expected": "-inf", "mode": "equal" },
        { "method": "maximum",  "args": [],      "expected": 110.0,  "mode": "equal" },
        { "method": "pdf",      "args": [100.0], "expected": 0.025,  "mode": "abs",  "tol": 1e-12 },
        { "method": "cdf",      "args": [100.0], "expected": 0.5,    "mode": "abs",  "tol": 1e-12 },
        { "method": "quantile", "args": [0.5],   "expected": 100.0,  "mode": "abs",  "tol": 1e-9 }
      ]
    },
    {
      "name": "negative_kappa_bounded_below",
      "comment": "xi=100, alpha=10, kappa=-5: bounded below at xi+alpha/kappa=98, unbounded above",
      "construct": { "params": [100.0, 10.0, -5.0] },
      "assertions": [
        { "method": "minimum",  "args": [],  "expected": 98.0,  "mode": "abs", "tol": 1e-9 },
        { "method": "maximum",  "args": [],  "expected": "inf", "mode": "equal" }
      ]
    },
    {
      "name": "invalid_nan",
      "construct": { "params": ["nan", "nan", "nan"] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "invalid_zero_scale",
      "construct": { "params": [100.0, 0.0, 1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "lmom_fit",
      "construct": { "fit": { "dataset": "lmom_sample", "method": "lmom" } },
      "assertions": [
        { "method": "param",         "args": [0], "expected": 1625.42,    "mode": "abs", "tol": 0.001 },
        { "method": "param",         "args": [1], "expected": 135.8186,   "mode": "abs", "tol": 0.001 },
        { "method": "param",         "args": [2], "expected": -0.1033903, "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [0], "expected": 1648.806,   "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [1], "expected": 138.2366,   "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [2], "expected": 0.1033903,  "mode": "abs", "tol": 0.001 },
        { "method": "linear_moment", "args": [3], "expected": 0.1755746,  "mode": "abs", "tol": 0.001 }
      ]
    },
    {
      "name": "mle_fit",
      "comment": "tolerances relaxed vs C# test to account for Nelder-Mead path differences",
      "construct": { "fit": { "dataset": "east_fork_white", "method": "mle" } },
      "assertions": [
        { "method": "param", "args": [0], "expected": 30911.83,  "mode": "rel", "tol": 0.05 },
        { "method": "param", "args": [1], "expected": 9305.0205, "mode": "rel", "tol": 0.05 },
        { "method": "param", "args": [2], "expected": -0.144152, "mode": "rel", "tol": 0.10 }
      ]
    }
  ]
}
