{
  "target": "Geometric",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_Geometric.cs",
  "cases": [
    {
      "name": "p0.5_standard",
      "construct": { "params": [0.5] },
      "assertions": [
        { "method": "mean",     "args": [], "expected": 1.0,      "mode": "abs", "tol": 1e-4 },
        { "method": "mode",     "args": [], "expected": 0.0,      "mode": "abs", "tol": 1e-4 },
        { "method": "sd",       "args": [], "expected": 1.41421,  "mode": "abs", "tol": 1e-4 },
        { "method": "skewness", "args": [], "expected": 2.12132,  "mode": "abs", "tol": 1e-4 },
        { "method": "kurtosis", "args": [], "expected": 9.5,      "mode": "abs", "tol": 1e-4 },
        { "method": "pdf",      "args": [0.0],  "expected": 0.5,   "mode": "abs", "tol": 1e-12 },
        { "method": "pdf",      "args": [2.0],  "expected": 0.125, "mode": "abs", "tol": 1e-12 },
        { "method": "pdf",      "args": [-1.0], "expected": 0.0,   "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [0.0],  "expected": 0.5,   "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [2.0],  "expected": 0.875, "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [-1.0], "expected": 0.0,   "mode": "abs", "tol": 1e-12 },
        { "method": "quantile", "args": [0.3],  "expected": 0.0,   "mode": "abs", "tol": 1e-4 },
        { "method": "quantile", "args": [0.7],  "expected": 1.0,   "mode": "abs", "tol": 1e-4 },
        { "method": "parameters_valid", "args": [], "expected": true, "mode": "bool" }
      ]
    },
