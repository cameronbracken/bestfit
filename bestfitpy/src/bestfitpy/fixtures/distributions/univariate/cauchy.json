{
  "target": "Cauchy",
  "kind": "univariate_distribution",
  "source": "Numerics/Test_Numerics/Distributions/Univariate/Test_Cauchy.cs",
  "cases": [
    {
      "name": "standard_0_1",
      "construct": { "params": [0.0, 1.0] },
      "assertions": [
        { "method": "pdf",      "args": [0.0],  "expected": 0.3183098861837907,  "mode": "abs", "tol": 1e-12 },
        { "method": "cdf",      "args": [0.0],  "expected": 0.5,                 "mode": "equal" },
        { "method": "quantile", "args": [0.5],  "expected": 0.0,                 "mode": "equal" },
        { "method": "mean",     "args": [],      "expected": "nan",               "mode": "equal" },
        { "method": "median",   "args": [],      "expected": 0.0,                 "mode": "equal" },
        { "method": "mode",     "args": [],      "expected": 0.0,                 "mode": "equal" },
        { "method": "sd",       "args": [],      "expected": "nan",               "mode": "equal" },
        { "method": "skewness", "args": [],      "expected": "nan",               "mode": "equal" },
        { "method": "kurtosis", "args": [],      "expected": "nan",               "mode": "equal" },
        { "method": "minimum",  "args": [],      "expected": "-inf",              "mode": "equal" },
        { "method": "maximum",  "args": [],      "expected": "inf",               "mode": "equal" },
        { "method": "parameters_valid", "args": [], "expected": true,             "mode": "bool" }
      ]
    },
    {
      "name": "params_0p42_1p57",
      "construct": { "params": [0.42, 1.57] },
      "assertions": [
        { "method": "mean",     "args": [],      "expected": "nan",               "mode": "equal" },
        { "method": "median",   "args": [],      "expected": 0.42,                "mode": "abs", "tol": 1e-12 },
        { "method": "mode",     "args": [],      "expected": 0.42,                "mode": "abs", "tol": 1e-12 },
        { "method": "sd",       "args": [],      "expected": "nan",               "mode": "equal" },
        { "method": "skewness", "args": [],      "expected": "nan",               "mode": "equal" },
        { "method": "kurtosis", "args": [],      "expected": "nan",               "mode": "equal" },
        { "method": "pdf",      "args": [0.27],  "expected": 0.2009112009763413,  "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [0.27],  "expected": 0.4696802584160856,  "mode": "abs", "tol": 1e-10 },
        { "method": "quantile", "args": [0.69358638272337991], "expected": 1.513030467445629, "mode": "abs", "tol": 1e-9 }
      ]
    },
    {
      "name": "params_0_0p1",
      "construct": { "params": [0.0, 0.1] },
      "assertions": [
        { "method": "pdf",      "args": [-5.0], "expected": 0.001272730452554141, "mode": "abs", "tol": 1e-10 },
        { "method": "pdf",      "args": [0.0],  "expected": 3.183098861837907,    "mode": "abs", "tol": 1e-10 },
        { "method": "pdf",      "args": [1.0],  "expected": 0.0315158303152268,   "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [-5.0], "expected": 0.006365349100972806, "mode": "abs", "tol": 1e-8 },
        { "method": "cdf",      "args": [0.0],  "expected": 0.5,                  "mode": "equal" },
        { "method": "cdf",      "args": [1.0],  "expected": 0.9682744825694465,   "mode": "abs", "tol": 1e-8 },
        { "method": "quantile", "args": [0.1],  "expected": -0.3077683537175253,  "mode": "abs", "tol": 1e-8 },
        { "method": "quantile", "args": [0.3],  "expected": -0.0726542528005361,  "mode": "abs", "tol": 1e-8 },
        { "method": "quantile", "args": [0.9],  "expected": 0.3077683537175253,   "mode": "abs", "tol": 1e-8 }
      ]
    },
    {
      "name": "params_neg5_100",
      "construct": { "params": [-5.0, 100.0] },
      "assertions": [
        { "method": "pdf",      "args": [-5.0], "expected": 0.003183098861837907, "mode": "abs", "tol": 1e-10 },
        { "method": "pdf",      "args": [0.0],  "expected": 0.003175160959439309, "mode": "abs", "tol": 1e-10 },
        { "method": "pdf",      "args": [1.0],  "expected": 0.0031716808109186,   "mode": "abs", "tol": 1e-10 },
        { "method": "cdf",      "args": [-5.0], "expected": 0.5,                  "mode": "equal" },
        { "method": "cdf",      "args": [0.0],  "expected": 0.5159022512561764,   "mode": "abs", "tol": 1e-8 },
        { "method": "cdf",      "args": [1.0],  "expected": 0.5190757242358363,   "mode": "abs", "tol": 1e-8 },
        { "method": "quantile", "args": [0.1],  "expected": -312.7683537175253,   "mode": "abs", "tol": 1e-6 },
        { "method": "quantile", "args": [0.3],  "expected": -77.65425280053609,   "mode": "abs", "tol": 1e-6 },
        { "method": "quantile", "args": [0.9],  "expected": 302.7683537175253,    "mode": "abs", "tol": 1e-6 }
      ]
    },
    {
      "name": "invalid_nan_location",
      "construct": { "params": ["nan", 1.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    },
    {
      "name": "invalid_zero_scale",
      "construct": { "params": [1.0, 0.0] },
      "assertions": [
        { "method": "parameters_valid", "args": [], "expected": false, "mode": "bool" }
      ]
    }
  ]
}
